<%- include('partials/head', { title: 'Residences', bodyClass: 'residences-page', description: 'Residences in Kelibia.' }) %>
<%- include('partials/navbar', { page: 'residences', properties }) %>

<main class="bg-[#fbf7ef]">
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between gap-6">
      <div>
        <p class="text-xs uppercase tracking-[0.32em] text-[#8c7752]">Residences</p>
        <h1 class="mt-4 font-display text-5xl text-[#243746]">Modern Residences</h1>
        <p class="mt-3 text-sm text-[#5c7280]">40 residences, 12 properties per page.</p>
      </div>
      <div class="rounded-[1.5rem] border border-[#eadfca] bg-white px-5 py-4 text-right">
        <p class="text-sm text-[#8c7752]">Page</p>
        <p class="mt-1 text-3xl font-bold text-[#243746]"><%= pagination.currentPage %></p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-12 sm:px-6 lg:px-8">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      <% residences.forEach(function(property){ %>
        <article class="ui-card overflow-hidden rounded-[1.75rem] transition duration-300 hover:-translate-y-1 hover:shadow-lg">
          <div class="h-2 bg-[#c9a46a]"></div>
          <img src="<%= property.thumbnail %>" alt="<%= property.title %>" class="h-64 w-full object-cover">
          <div class="p-6">
            <h2 class="text-2xl font-semibold text-[#243746]"><a href="/property/<%= property.id %>"><%= property.title %></a></h2>
            <p class="mt-2 text-sm text-[#6a7f8a]"><%= property.zone %></p>
            <p class="mt-4 text-sm text-[#4f6674]"><%= property.apartmentCount %> apartments</p>
            <p class="mt-1 text-sm text-[#4f6674]"><%= property.availableTypes.join(' / ') %></p>
            <p class="mt-4 text-base font-semibold text-[#8f6a36]">Starting from <%= formatPrice({ price: getResidenceStartingPrice(property) }) %></p>
          </div>
        </article>
      <% }); %>
    </div>

    <%- include('partials/pagination', { pagination, basePath: '/residences', querySuffix }) %>
  </section>
</main>

<%- include('partials/footer') %>
