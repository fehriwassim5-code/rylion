<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> | Rylion Immobilière</title>
  <meta name="description" content="<%= description %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Cormorant+Garamond:wght@500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --sand: #f6f1e8;
      --sand-deep: #ebe2d2;
      --navy: #12354a;
      --navy-deep: #0b2331;
      --gold: #b79b67;
      --gold-soft: #d7c2a0;
      --charcoal: #22201d;
      --muted: #6c665f;
      --white: #fffdf8;
      --line: rgba(18, 53, 74, 0.12);
      --shadow: 0 24px 70px rgba(11, 35, 49, 0.12);
      --container: 1240px;
      --radius-xl: 34px;
      --radius-lg: 24px;
      --radius-md: 18px;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: "Manrope", sans-serif;
      color: var(--charcoal);
      background:
        radial-gradient(circle at top right, rgba(183, 155, 103, 0.16), transparent 28%),
        linear-gradient(180deg, #fbf7f0 0%, var(--sand) 42%, #f9f5ee 100%);
      overflow-x: hidden;
    }
    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }
    main { width: 100%; }
    button, input, textarea, select { font: inherit; }
    .container { width: min(var(--container), calc(100% - 32px)); margin: 0 auto; }
    .min-h-screen { min-height: 100vh; }
    .hidden { display: none !important; }
    .relative { position: relative; }
    .absolute { position: absolute; }
    .top-3 { top: 12px; } .top-4 { top: 16px; } .left-3 { left: 12px; } .left-4 { left: 16px; } .right-3 { right: 12px; } .bottom-3 { bottom: 12px; } .-top-2 { top: -8px; } .-right-2 { right: -8px; }
    .max-w-6xl { width: min(var(--container), calc(100% - 32px)); max-width: var(--container); }
    .mx-auto { margin-left: auto; margin-right: auto; }
    .mt-1 { margin-top: 4px; } .mt-2 { margin-top: 8px; } .mt-3 { margin-top: 12px; } .mt-4 { margin-top: 16px; }
    .mb-1 { margin-bottom: 4px; } .mb-2 { margin-bottom: 8px; } .m-0 { margin: 0; }
    .p-2 { padding: 8px; } .p-4 { padding: 16px; } .p-5 { padding: 20px; } .p-6 { padding: 24px; }
    .px-3 { padding-left: 12px; padding-right: 12px; } .px-4 { padding-left: 16px; padding-right: 16px; } .py-1 { padding-top: 4px; padding-bottom: 4px; } .py-2 { padding-top: 8px; padding-bottom: 8px; } .py-7 { padding-top: 28px; padding-bottom: 28px; } .py-10 { padding-top: 40px; padding-bottom: 40px; }
    .pr-3 { padding-right: 12px; } .pt-2 { padding-top: 8px; } .pt-3 { padding-top: 12px; }
    .space-y-2 > * + * { margin-top: 8px; } .space-y-3 > * + * { margin-top: 12px; } .space-y-4 > * + * { margin-top: 16px; } .space-y-5 > * + * { margin-top: 20px; } .space-y-6 > * + * { margin-top: 24px; } .space-y-8 > * + * { margin-top: 32px; } .space-y-10 > * + * { margin-top: 40px; }
    .grid { display: grid; } .flex { display: flex; } .inline-flex { display: inline-flex; }
    .flex-col { flex-direction: column; } .flex-wrap { flex-wrap: wrap; }
    .items-center { align-items: center; } .items-start { align-items: flex-start; } .items-end { align-items: flex-end; }
    .justify-between { justify-content: space-between; } .justify-center { justify-content: center; } .text-center { text-align: center; }
    .gap-1 { gap: 4px; } .gap-2 { gap: 8px; } .gap-3 { gap: 12px; } .gap-4 { gap: 16px; } .gap-6 { gap: 24px; }
    .grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .w-full { width: 100%; } .w-fit { width: fit-content; } .min-w-full { min-width: 100%; }
    .h-6 { height: 24px; } .h-8 { height: 32px; } .h-10 { height: 40px; } .h-20 { height: 80px; } .h-24 { height: 96px; } .h-28 { height: 112px; } .h-40 { height: 160px; } .h-44 { height: 176px; } .h-48 { height: 192px; } .h-96 { height: 384px; }
    .w-6 { width: 24px; } .w-8 { width: 32px; } .w-10 { width: 40px; }
    .object-cover { object-fit: cover; }
    .overflow-hidden { overflow: hidden; } .overflow-auto { overflow: auto; }
    .whitespace-nowrap { white-space: nowrap; }
    .border { border: 1px solid rgba(18, 53, 74, 0.12); } .border-2 { border-width: 2px; } .border-dashed { border-style: dashed; } .border-t { border-top: 1px solid rgba(18, 53, 74, 0.1); } .border-b { border-bottom: 1px solid rgba(18, 53, 74, 0.1); }
    .border-brand-ink\/5 { border-color: rgba(18, 53, 74, 0.05); } .border-brand-ink\/10 { border-color: rgba(18, 53, 74, 0.1); } .border-brand-ink\/15 { border-color: rgba(18, 53, 74, 0.15); } .border-brand-ink\/20 { border-color: rgba(18, 53, 74, 0.2); } .border-brand-gold { border-color: var(--gold); } .border-red-700 { border-color: #b91c1c; }
    .rounded-md { border-radius: 6px; } .rounded-lg { border-radius: 10px; } .rounded-xl { border-radius: 14px; } .rounded-2xl { border-radius: 20px; } .rounded-3xl { border-radius: 30px; } .rounded-full { border-radius: 999px; }
    .bg-white { background: #fff; } .bg-white\/90 { background: rgba(255, 255, 255, 0.9); } .bg-brand-ink { background: var(--navy-deep); } .bg-brand-sand { background: var(--sand); } .bg-brand-sand\/30 { background: rgba(246, 241, 232, 0.3); } .bg-brand-sand\/40 { background: rgba(246, 241, 232, 0.4); } .bg-brand-sand\/60 { background: rgba(246, 241, 232, 0.6); } .bg-brand-gold { background: var(--gold); } .bg-red-600 { background: #dc2626; } .bg-red-700, .hover\:bg-red-700:hover { background: #b91c1c; }
    .bg-gradient-to-b, .bg-gradient-to-r { background: linear-gradient(180deg, #fff 0%, var(--sand) 54%, #fff 100%); }
    .text-white { color: #fff; } .text-red-700 { color: #b91c1c; } .text-brand-ink { color: var(--navy-deep); } .text-brand-ink\/50 { color: rgba(11, 35, 49, 0.5); } .text-brand-ink\/55 { color: rgba(11, 35, 49, 0.55); } .text-brand-ink\/60 { color: rgba(11, 35, 49, 0.6); } .text-brand-ink\/68 { color: rgba(11, 35, 49, 0.68); } .text-brand-ink\/70 { color: rgba(11, 35, 49, 0.7); } .text-brand-ink\/80 { color: rgba(11, 35, 49, 0.8); }
    .text-\[10px\] { font-size: 10px; } .text-\[11px\] { font-size: 11px; } .text-xs { font-size: 12px; } .text-sm { font-size: 14px; } .text-lg { font-size: 18px; } .text-xl { font-size: 20px; } .text-2xl { font-size: 24px; } .text-3xl { font-size: 30px; } .text-4xl { font-size: 36px; }
    .font-semibold { font-weight: 700; } .font-bold { font-weight: 800; } .uppercase { text-transform: uppercase; } .tracking-\[0\.25em\] { letter-spacing: 0.25em; }
    .shadow, .shadow-sm, .shadow-lg { box-shadow: 0 20px 44px rgba(11, 35, 49, 0.1); }
    .transition { transition: transform 0.24s ease, box-shadow 0.24s ease, border-color 0.24s ease, background-color 0.24s ease; }
    .hover\:-translate-y-1:hover { transform: translateY(-4px); } .hover\:-translate-y-0\.5:hover { transform: translateY(-2px); } .hover\:border-brand-ink\/30:hover { border-color: rgba(18, 53, 74, 0.3); }
    .cursor-pointer { cursor: pointer; } .align-top { vertical-align: top; }
    .tw-btn-primary, .tw-btn-ghost {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      padding: 10px 16px;
      border-radius: 999px;
      border: 1px solid rgba(18, 53, 74, 0.14);
      font-weight: 800;
      cursor: pointer;
      transition: transform 0.24s ease, box-shadow 0.24s ease, background-color 0.24s ease;
    }
    .tw-btn-primary { background: linear-gradient(135deg, var(--navy), #1d516d); color: var(--white); box-shadow: 0 12px 28px rgba(18, 53, 74, 0.18); }
    .tw-btn-ghost { background: rgba(255, 253, 248, 0.78); color: var(--navy-deep); }
    .tw-btn-primary:hover, .tw-btn-ghost:hover { transform: translateY(-2px); }
    @media (min-width: 640px) {
      .sm\:px-6 { padding-left: 24px; padding-right: 24px; }
      .sm\:p-5 { padding: 20px; }
      .sm\:text-4xl { font-size: 36px; }
      .sm\:items-end { align-items: flex-end; }
    }
    @media (min-width: 768px) {
      .md\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .md\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
      .md\:col-span-2 { grid-column: span 2 / span 2; }
      .md\:flex-row { flex-direction: row; }
      .md\:items-center { align-items: center; }
      .md\:items-end { align-items: flex-end; }
      .md\:justify-between { justify-content: space-between; }
    }
    @media (min-width: 1024px) {
      .lg\:flex-row { flex-direction: row; }
      .lg\:items-center { align-items: center; }
      .lg\:justify-between { justify-content: space-between; }
    }
    @media (max-width: 720px) {
      .max-w-6xl { width: min(100% - 24px, var(--container)); }
      .grid-cols-3 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .text-3xl { font-size: 28px; }
      .text-4xl { font-size: 32px; }
    }
    .section { padding: 42px 0 88px; }
    .section-head { display: grid; grid-template-columns: 1fr auto; gap: 24px; align-items: end; margin-bottom: 32px; }
    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      color: var(--navy);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }
    .eyebrow::before { content: ""; width: 42px; height: 1px; background: rgba(18, 53, 74, 0.3); }
    h1, h2, h3, h4, h5, h6 {
      margin: 0;
      font-family: "Cormorant Garamond", serif;
      letter-spacing: -0.03em;
      color: var(--navy-deep);
    }
    .title { margin-top: 16px; font-size: clamp(40px, 7vw, 82px); line-height: 0.92; }
    .subtitle { margin: 18px 0 0; max-width: 640px; color: var(--muted); font-size: 18px; line-height: 1.75; }
    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 56px;
      padding: 0 28px;
      border-radius: 999px;
      border: 1px solid transparent;
      font-weight: 700;
      transition: transform 0.28s ease, box-shadow 0.28s ease, background-color 0.28s ease, color 0.28s ease, border-color 0.28s ease;
      cursor: pointer;
    }
    .button:hover { transform: translateY(-2px); }
    .button--primary {
      background: linear-gradient(135deg, var(--navy) 0%, #1d516d 100%);
      color: var(--white);
      box-shadow: 0 16px 36px rgba(18, 53, 74, 0.24);
    }
    .button--secondary {
      border-color: rgba(18, 53, 74, 0.18);
      background: rgba(255, 253, 248, 0.76);
      color: var(--navy-deep);
      backdrop-filter: blur(8px);
    }
    .button--hero {
      background: linear-gradient(135deg, #ffb347 0%, #ff8f3f 48%, #ff6b2c 100%);
      color: #fffaf2;
      box-shadow: 0 18px 38px rgba(255, 107, 44, 0.34);
      border-color: rgba(255, 255, 255, 0.14);
    }
    .button--hero:hover {
      background: linear-gradient(135deg, #ffc067 0%, #ff9e4f 48%, #ff7b3d 100%);
      box-shadow: 0 22px 42px rgba(255, 107, 44, 0.4);
    }
    .site-header {
      position: sticky;
      top: 0;
      z-index: 20;
      background: rgba(250, 246, 238, 0.82);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid rgba(18, 53, 74, 0.08);
    }
    .site-header__row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      min-height: 86px;
    }
    .brand { display: flex; align-items: center; gap: 14px; }
    .brand__mark {
      width: 48px;
      height: 48px;
      border-radius: 18px;
      display: grid;
      place-items: center;
      background: linear-gradient(145deg, var(--navy-deep), var(--navy));
      color: var(--gold-soft);
      font-family: "Cormorant Garamond", serif;
      font-size: 28px;
      font-weight: 700;
      box-shadow: 0 16px 28px rgba(18, 53, 74, 0.22);
    }
    .brand__text small {
      display: block;
      color: var(--muted);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }
    .brand__text strong {
      display: block;
      margin-top: 3px;
      font-size: 22px;
      font-family: "Cormorant Garamond", serif;
      color: var(--navy-deep);
    }
    .site-nav { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .site-nav a {
      padding: 12px 18px;
      border-radius: 999px;
      color: var(--muted);
      font-weight: 700;
      transition: background-color 0.24s ease, color 0.24s ease;
    }
    .site-nav a:hover, .site-nav a.is-active { background: rgba(18, 53, 74, 0.08); color: var(--navy-deep); }
    .hero-shell { position: relative; min-height: calc(100vh - 86px); padding: 26px 0 44px; }
    .hero {
      position: relative;
      min-height: calc(100vh - 156px);
      border-radius: 40px;
      overflow: hidden;
      background: #102a39;
      box-shadow: var(--shadow);
    }
    .hero__image, .property-card__media img, .gallery-main img, .gallery-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .hero__image { position: absolute; inset: 0; }
    .hero__overlay {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(105deg, rgba(9, 29, 41, 0.82) 0%, rgba(13, 39, 54, 0.62) 40%, rgba(13, 39, 54, 0.18) 78%),
        linear-gradient(180deg, rgba(255, 255, 255, 0) 35%, rgba(9, 29, 41, 0.28) 100%);
    }
    .hero__content {
      position: relative;
      z-index: 1;
      min-height: calc(100vh - 156px);
      display: grid;
      align-items: end;
      grid-template-columns: 1fr;
      gap: 28px;
      padding: 44px;
      color: var(--white);
    }
    .hero__content h1 { color: var(--white); }
    .hero__content .subtitle { color: rgba(255, 253, 248, 0.82); max-width: 540px; }
    .hero__cta { margin-top: 28px; }
    .hero__aside { align-self: stretch; display: grid; align-items: end; }
    .floating-card {
      background: rgba(255, 253, 248, 0.12);
      border: 1px solid rgba(255, 253, 248, 0.22);
      backdrop-filter: blur(14px);
      border-radius: 30px;
      padding: 28px;
      transform: translateY(0);
      animation: drift 6s ease-in-out infinite;
    }
    .floating-card h3, .floating-card strong { color: var(--white); }
    .floating-card p, .floating-card span { color: rgba(255, 253, 248, 0.76); }
    .floating-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; margin-top: 24px; }
    .floating-metric { padding: 16px 18px; border-radius: 20px; background: rgba(255, 253, 248, 0.08); }
    .floating-metric strong { display: block; font-size: 26px; }
    .floating-metric span { display: block; margin-top: 6px; font-size: 13px; line-height: 1.5; }
    .listing-layout, .detail-layout, .contact-layout, .feature-grid { display: grid; gap: 24px; }
    .feature-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .listing-layout { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .detail-layout, .contact-layout { grid-template-columns: 1.1fr 0.9fr; align-items: start; }
    .panel, .property-card, .detail-card, .contact-card, .info-card {
      border: 1px solid var(--line);
      border-radius: var(--radius-xl);
      background: rgba(255, 253, 248, 0.74);
      box-shadow: var(--shadow);
      backdrop-filter: blur(10px);
    }
    .panel, .detail-card, .contact-card, .info-card { padding: 28px; }
    .feature-card {
      padding: 28px;
      border-radius: var(--radius-lg);
      border: 1px solid rgba(18, 53, 74, 0.12);
      background: linear-gradient(180deg, rgba(255, 253, 248, 0.86), rgba(242, 234, 221, 0.8));
      box-shadow: 0 14px 40px rgba(18, 53, 74, 0.08);
    }
    .feature-card strong {
      display: block;
      margin-top: 18px;
      font-size: 29px;
      font-family: "Cormorant Garamond", serif;
      color: var(--navy-deep);
    }
    .feature-card p { margin: 10px 0 0; color: var(--muted); line-height: 1.7; }
    .feature-chip {
      display: inline-flex;
      align-items: center;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(183, 155, 103, 0.16);
      color: var(--navy);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .property-card {
      overflow: hidden;
      transition: transform 0.32s ease, box-shadow 0.32s ease;
      display: flex;
      flex-direction: column;
      min-height: 100%;
    }
    .property-card:hover { transform: translateY(-6px); box-shadow: 0 32px 68px rgba(11, 35, 49, 0.16); }
    .property-card--large { grid-column: span 1; }
    .property-card--medium { grid-column: span 1; }
    .property-card--regular { grid-column: span 1; }
    .property-card__media { position: relative; aspect-ratio: 1.15 / 1; overflow: hidden; background: var(--sand-deep); }
    .property-card__media::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(11, 35, 49, 0) 32%, rgba(11, 35, 49, 0.24) 100%);
    }
    .property-card:hover .property-card__media img, .gallery-thumb:hover img { transform: scale(1.04); }
    .property-card__media img, .gallery-thumb img { transition: transform 0.45s ease; }
    .property-card__body { padding: 24px; display: grid; gap: 14px; }
    .property-card__price { display: flex; align-items: center; justify-content: space-between; gap: 18px; font-size: 14px; color: var(--muted); }
    .property-card__price strong {
      font-size: clamp(25px, 3vw, 34px);
      color: var(--navy-deep);
      font-family: "Cormorant Garamond", serif;
    }
    .property-card__price-empty {
      min-width: 1px;
      min-height: 1px;
    }
    .property-card__villa-price {
      font-family: "Manrope", sans-serif !important;
      font-size: clamp(22px, 2vw, 28px) !important;
      font-weight: 800 !important;
      letter-spacing: -0.02em;
    }
    .property-card__title { font-size: clamp(28px, 3vw, 38px); line-height: 0.96; }
    .property-card__location { color: var(--muted); font-size: 15px; }
    .property-card__meta { display: grid; gap: 10px; color: var(--muted); font-size: 14px; line-height: 1.6; }
    .property-card__inline-price {
      font-family: "Manrope", sans-serif;
      font-size: 14px;
      font-weight: 800;
      color: var(--navy-deep);
      letter-spacing: -0.01em;
    }
    .properties-page .listing-layout { gap: 18px; }
    .properties-page .property-card {
      border-radius: 26px;
      box-shadow: 0 18px 42px rgba(11, 35, 49, 0.12);
    }
    .properties-page .property-card__media { aspect-ratio: 1.12 / 0.78; }
    .properties-page .property-card__body { padding: 18px; gap: 10px; }
    .properties-page .property-card__price strong { font-size: clamp(22px, 2vw, 28px); }
    .properties-page .property-card__title { font-size: clamp(24px, 2.2vw, 30px); }
    .properties-page .property-card__location { font-size: 14px; }
    .properties-page .property-card__meta { gap: 6px; font-size: 13px; }
    .properties-page .meta-pill { padding: 8px 12px; font-size: 11px; }
    .pill-row, .stats-row { display: flex; flex-wrap: wrap; gap: 10px; }
    .meta-pill {
      display: inline-flex;
      align-items: center;
      padding: 9px 14px;
      border-radius: 999px;
      background: rgba(18, 53, 74, 0.08);
      color: var(--navy);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .stats-bar { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; margin-top: 18px; }
    .stat-card {
      padding: 22px;
      border-radius: 24px;
      background: linear-gradient(180deg, rgba(255, 253, 248, 0.9), rgba(241, 233, 220, 0.86));
      border: 1px solid rgba(18, 53, 74, 0.1);
    }
    .stat-card strong {
      display: block;
      font-size: 34px;
      font-family: "Cormorant Garamond", serif;
      color: var(--navy-deep);
    }
    .stat-card span { display: block; margin-top: 8px; color: var(--muted); line-height: 1.6; }
    .gallery-main {
      aspect-ratio: 1.28 / 1;
      border-radius: 32px;
      overflow: hidden;
      background: var(--sand-deep);
      box-shadow: var(--shadow);
    }
    .gallery-strip { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; margin-top: 16px; }
    .gallery-thumb { aspect-ratio: 1 / 0.84; border-radius: 22px; overflow: hidden; background: var(--sand-deep); }
    .detail-card { position: sticky; top: 110px; }
    .detail-card__price { margin-top: 18px; font-size: 44px; color: var(--navy-deep); font-family: "Cormorant Garamond", serif; }
    .detail-card__location { margin-top: 10px; color: var(--muted); font-size: 17px; line-height: 1.7; }
    .detail-list, .unit-table { display: grid; gap: 14px; margin-top: 24px; }
    .detail-row, .unit-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 18px;
      align-items: center;
      padding: 18px 20px;
      border-radius: 22px;
      background: rgba(18, 53, 74, 0.05);
      border: 1px solid rgba(18, 53, 74, 0.08);
    }
    .detail-row strong, .unit-row strong { font-size: 19px; font-family: "Cormorant Garamond", serif; color: var(--navy-deep); }
    .detail-row span, .unit-row span { color: var(--muted); font-weight: 700; text-align: right; }
    .unit-section + .unit-section { margin-top: 26px; }
    .unit-section h3 { font-size: 34px; }
    .unit-section p { margin: 8px 0 0; color: var(--muted); line-height: 1.7; }
    .contact-list { display: grid; gap: 14px; margin-top: 24px; }
    .contact-point {
      padding: 18px 20px;
      border-radius: 22px;
      background: rgba(18, 53, 74, 0.05);
      border: 1px solid rgba(18, 53, 74, 0.08);
    }
    .contact-point strong { display: block; margin-bottom: 6px; font-size: 18px; font-family: "Cormorant Garamond", serif; color: var(--navy-deep); }
    .contact-point span { color: var(--muted); line-height: 1.7; }
    .contact-form { display: grid; gap: 16px; margin-top: 24px; }
    .field {
      width: 100%;
      padding: 16px 18px;
      border-radius: 18px;
      border: 1px solid rgba(18, 53, 74, 0.14);
      background: rgba(255, 253, 248, 0.96);
      color: var(--charcoal);
      transition: border-color 0.24s ease, box-shadow 0.24s ease;
    }
    .field:focus { outline: none; border-color: rgba(183, 155, 103, 0.8); box-shadow: 0 0 0 4px rgba(183, 155, 103, 0.16); }
    textarea.field { min-height: 160px; resize: vertical; }
    .alert { padding: 16px 18px; border-radius: 18px; background: rgba(183, 155, 103, 0.16); color: var(--navy-deep); border: 1px solid rgba(183, 155, 103, 0.35); }
    .pagination { display: flex; justify-content: center; gap: 10px; flex-wrap: wrap; margin-top: 38px; }
    .pagination a, .pagination span {
      width: 48px;
      height: 48px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      background: rgba(255, 253, 248, 0.78);
      border: 1px solid rgba(18, 53, 74, 0.12);
      color: var(--muted);
      font-weight: 800;
    }
    .pagination .is-current {
      background: linear-gradient(135deg, var(--navy), #1d516d);
      color: var(--white);
      border-color: transparent;
      box-shadow: 0 14px 28px rgba(18, 53, 74, 0.2);
    }
    .site-footer { padding: 26px 0 40px; border-top: 1px solid rgba(18, 53, 74, 0.08); color: var(--muted); font-size: 14px; }
    .site-footer__row { display: flex; align-items: center; justify-content: space-between; gap: 18px; flex-wrap: wrap; }
    .home-page .hero-shell {
      overflow: hidden;
      padding-top: 18px;
    }
    .home-page .hero {
      min-height: calc(100vh - 132px);
      background:
        radial-gradient(circle at 15% 20%, rgba(31, 119, 173, 0.55), transparent 24%),
        radial-gradient(circle at 82% 18%, rgba(220, 183, 103, 0.42), transparent 22%),
        radial-gradient(circle at 65% 80%, rgba(10, 39, 58, 0.68), transparent 28%),
        linear-gradient(135deg, #081c2a 0%, #12354a 48%, #0f5e88 100%);
      border: 1px solid rgba(255, 253, 248, 0.12);
    }
    .home-page .hero__overlay {
      background:
        linear-gradient(105deg, rgba(5, 20, 32, 0.78) 0%, rgba(7, 28, 43, 0.48) 42%, rgba(7, 28, 43, 0.12) 76%),
        radial-gradient(circle at 78% 24%, rgba(255, 210, 133, 0.18), transparent 28%);
    }
    .home-page .hero__content {
      grid-template-columns: 1fr 1.1fr;
      align-items: center;
      gap: 36px;
      min-height: calc(100vh - 132px);
      padding: 42px;
    }
    .home-page .hero__panel {
      position: relative;
      z-index: 2;
      max-width: 560px;
    }
    .home-page .hero__panel .eyebrow {
      color: rgba(255, 244, 224, 0.92);
    }
    .home-page .hero__panel .eyebrow::before {
      background: rgba(255, 244, 224, 0.4);
    }
    .home-page .hero__panel .title {
      color: var(--white);
      text-shadow: 0 18px 48px rgba(5, 18, 28, 0.34);
    }
    .home-page .hero__panel .subtitle {
      color: rgba(255, 250, 242, 0.82);
    }
    .hero-microcopy {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 18px;
    }
    .hero-microcopy span {
      display: inline-flex;
      align-items: center;
      padding: 9px 14px;
      border-radius: 999px;
      background: rgba(255, 253, 248, 0.1);
      border: 1px solid rgba(255, 253, 248, 0.12);
      color: rgba(255, 250, 242, 0.84);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      backdrop-filter: blur(10px);
    }
    .hero-scene {
      position: relative;
      min-height: 560px;
      perspective: 1500px;
      transform-style: preserve-3d;
    }
    .hero-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(4px);
      opacity: 0.9;
      animation: pulseOrb 8s ease-in-out infinite;
    }
    .hero-orb--gold {
      width: 180px;
      height: 180px;
      top: 20px;
      right: 20px;
      background: radial-gradient(circle, rgba(236, 190, 109, 0.95) 0%, rgba(236, 190, 109, 0.12) 72%, transparent 100%);
    }
    .hero-orb--blue {
      width: 240px;
      height: 240px;
      left: 30px;
      bottom: 18px;
      background: radial-gradient(circle, rgba(48, 160, 224, 0.78) 0%, rgba(48, 160, 224, 0.08) 72%, transparent 100%);
      animation-delay: -2s;
    }
    .scene-frame {
      position: absolute;
      inset: 24px;
      border-radius: 40px;
      border: 1px solid rgba(255, 253, 248, 0.14);
      background: linear-gradient(180deg, rgba(255, 253, 248, 0.05), rgba(255, 253, 248, 0.01));
      transform: translateZ(-10px);
    }
    .scene-card {
      position: absolute;
      border-radius: 30px;
      overflow: hidden;
      border: 1px solid rgba(255, 253, 248, 0.18);
      box-shadow: 0 26px 54px rgba(4, 18, 28, 0.34);
      transform-style: preserve-3d;
      transition: transform 0.22s ease;
    }
    .scene-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .scene-card::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(8, 28, 42, 0) 20%, rgba(8, 28, 42, 0.42) 100%);
    }
    .scene-card--main {
      inset: 48px 54px 56px 120px;
      transform: rotateY(-13deg) rotateX(7deg) translateZ(30px);
    }
    .scene-card--small-a {
      width: 210px;
      height: 260px;
      left: 10px;
      top: 76px;
      transform: rotateY(18deg) rotateX(-6deg) translateZ(90px);
    }
    .scene-card--small-b {
      width: 250px;
      height: 172px;
      right: 6px;
      bottom: 24px;
      transform: rotateY(-20deg) rotateX(10deg) translateZ(110px);
    }
    .scene-caption {
      position: absolute;
      left: 26px;
      right: 26px;
      bottom: 24px;
      z-index: 1;
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 16px;
    }
    .scene-caption strong {
      color: var(--white);
      font-size: 32px;
      line-height: 0.95;
    }
    .scene-caption span {
      color: rgba(255, 250, 242, 0.76);
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .home-value-grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 24px;
      margin-top: 26px;
    }
    .home-value-card {
      padding: 30px;
      border-radius: 30px;
      background: rgba(255, 253, 248, 0.72);
      border: 1px solid rgba(18, 53, 74, 0.1);
      box-shadow: 0 20px 44px rgba(11, 35, 49, 0.08);
    }
    .home-value-card p {
      margin: 14px 0 0;
      color: var(--muted);
      line-height: 1.8;
    }
    .zone-ribbon {
      display: grid;
      gap: 14px;
      margin-top: 22px;
    }
    .zone-line {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 14px;
      align-items: center;
      color: var(--navy-deep);
    }
    .zone-line span {
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .zone-line i {
      height: 1px;
      background: linear-gradient(90deg, rgba(18, 53, 74, 0.18), rgba(18, 53, 74, 0.04));
    }
    .dashboard-section {
      padding: 0 0 88px;
    }
    .dashboard-shell {
      position: relative;
      margin-top: -46px;
      padding: 32px;
      border-radius: 32px;
      background:
        radial-gradient(circle at top left, rgba(255, 166, 77, 0.18), transparent 24%),
        linear-gradient(180deg, rgba(255, 253, 248, 0.94), rgba(244, 239, 231, 0.92));
      border: 1px solid rgba(18, 53, 74, 0.08);
      box-shadow: 0 26px 70px rgba(11, 35, 49, 0.14);
      overflow: hidden;
    }
    .dashboard-shell::after {
      content: "";
      position: absolute;
      inset: auto -120px -120px auto;
      width: 280px;
      height: 280px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(18, 83, 116, 0.14) 0%, rgba(18, 83, 116, 0) 72%);
      pointer-events: none;
    }
    .dashboard-head {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 24px;
      align-items: end;
      margin-bottom: 28px;
    }
    .dashboard-head p {
      margin: 14px 0 0;
      color: var(--muted);
      line-height: 1.75;
    }
    .dashboard-kpis {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 18px;
      margin-bottom: 22px;
    }
    .dashboard-kpi, .dashboard-chart-card {
      position: relative;
      padding: 22px;
      border-radius: 26px;
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid rgba(18, 53, 74, 0.08);
      box-shadow: 0 16px 38px rgba(11, 35, 49, 0.08);
      backdrop-filter: blur(10px);
    }
    .dashboard-kpi::before, .dashboard-chart-card::before {
      content: "";
      position: absolute;
      inset: 0 auto auto 0;
      width: 100%;
      height: 4px;
      background: linear-gradient(90deg, #ff9a3c, #145374, #0f8b8d);
    }
    .dashboard-kpi span {
      display: block;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(18, 53, 74, 0.56);
    }
    .dashboard-kpi strong {
      display: block;
      margin-top: 14px;
      font-size: clamp(28px, 3vw, 40px);
      font-family: "Cormorant Garamond", serif;
      color: var(--navy-deep);
      line-height: 0.94;
    }
    .dashboard-kpi p {
      margin: 10px 0 0;
      color: var(--muted);
      line-height: 1.7;
      font-size: 14px;
    }
    .dashboard-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px;
    }
    .dashboard-chart-card--wide {
      grid-column: 1 / -1;
    }
    .dashboard-chart-copy p {
      margin: 10px 0 0;
      color: var(--muted);
      line-height: 1.7;
    }
    .dashboard-chart {
      position: relative;
      min-height: 360px;
      margin-top: 14px;
    }
    .dashboard-chart svg {
      display: block;
      width: 100%;
      height: auto;
      overflow: visible;
    }
    .dashboard-legend {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: flex-end;
    }
    .dashboard-legend span {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--muted);
      font-size: 13px;
      font-weight: 700;
    }
    .dashboard-legend i {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      display: inline-block;
    }
    .dashboard-tooltip {
      position: absolute;
      z-index: 5;
      pointer-events: none;
      min-width: 140px;
      padding: 10px 12px;
      border-radius: 14px;
      background: rgba(11, 35, 49, 0.94);
      color: #fff;
      font-size: 13px;
      line-height: 1.5;
      box-shadow: 0 16px 30px rgba(0, 0, 0, 0.18);
      opacity: 0;
      transition: opacity 0.16s ease;
    }
    .dashboard-state {
      padding: 28px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.72);
      border: 1px dashed rgba(18, 53, 74, 0.18);
      color: var(--muted);
      text-align: center;
      font-weight: 700;
    }
    @keyframes pulseOrb {
      0%, 100% { transform: scale(1) translateY(0); opacity: 0.78; }
      50% { transform: scale(1.08) translateY(-10px); opacity: 1; }
    }
    @keyframes drift {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }
    @media (max-width: 1080px) {
      .hero__content, .detail-layout, .contact-layout, .feature-grid, .section-head { grid-template-columns: 1fr; }
      .detail-card { position: static; }
      .home-page .hero__content, .home-value-grid { grid-template-columns: 1fr; }
      .dashboard-head, .dashboard-grid, .dashboard-kpis { grid-template-columns: 1fr 1fr; }
      .dashboard-chart-card--wide { grid-column: auto; }
    }
    @media (max-width: 920px) {
      .listing-layout { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .stats-bar, .gallery-strip, .floating-grid { grid-template-columns: 1fr; }
      .home-page .hero__content { min-height: auto; }
      .hero-scene { min-height: 440px; }
      .scene-card--main { inset: 60px 34px 44px 74px; }
      .dashboard-head { grid-template-columns: 1fr; }
    }
    @media (max-width: 720px) {
      .site-header__row {
        min-height: 74px;
        flex-direction: column;
        justify-content: center;
        padding: 16px 0;
      }
      .site-nav { width: 100%; overflow-x: auto; justify-content: flex-start; padding-bottom: 4px; }
      .hero, .hero-shell { min-height: auto; }
      .hero__content { min-height: auto; padding: 28px; }
      .title { font-size: clamp(40px, 14vw, 64px); }
      .listing-layout, .gallery-strip, .stats-bar { grid-template-columns: 1fr; }
      .home-page .hero__content { grid-template-columns: 1fr; gap: 24px; }
      .hero-scene { min-height: 360px; }
      .scene-card--main { inset: 54px 20px 26px 46px; }
      .scene-card--small-a { width: 140px; height: 180px; left: 0; top: 62px; }
      .scene-card--small-b { width: 156px; height: 110px; right: 0; bottom: 18px; }
      .scene-caption { left: 18px; right: 18px; bottom: 16px; }
      .scene-caption strong { font-size: 24px; }
      .dashboard-shell { margin-top: -28px; padding: 22px; border-radius: 24px; }
      .dashboard-kpis, .dashboard-grid { grid-template-columns: 1fr; }
    }

  </style>
</head>
<body class="<%= bodyClass || '' %>">
