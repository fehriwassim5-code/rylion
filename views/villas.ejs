<%- include('partials/head', { title: 'Villas', bodyClass: 'villas-page', description: 'Villas in Kelibia.' }) %>
<%- include('partials/navbar', { page: 'villas', properties }) %>

<main class="bg-[#f5f1e8]">
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between gap-6">
      <div>
        <p class="text-xs uppercase tracking-[0.32em] text-[#295b74]">Villas</p>
        <h1 class="mt-4 font-display text-5xl text-[#243746]">Premium Villas</h1>
        <p class="mt-3 text-sm text-[#5c7280]">20 villas, 12 properties per page.</p>
      </div>
      <div class="rounded-[1.5rem] border border-[#dbe8f0] bg-white px-5 py-4 text-right">
        <p class="text-sm text-[#6a8796]">Page</p>
        <p class="mt-1 text-3xl font-bold text-[#243746]"><%= pagination.currentPage %></p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-12 sm:px-6 lg:px-8">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      <% villas.forEach(function(property){ %>
        <article class="ui-card overflow-hidden rounded-[1.75rem] transition duration-300 hover:-translate-y-1 hover:shadow-lg">
          <div class="h-2 bg-[#7aaec4]"></div>
          <img src="<%= property.thumbnail %>" alt="<%= property.title %>" class="h-64 w-full object-cover">
          <div class="p-6">
            <h2 class="text-2xl font-semibold text-[#243746]"><a href="/property/<%= property.id %>"><%= property.title %></a></h2>
            <p class="mt-2 text-sm text-[#6a7f8a]"><%= property.zone %></p>
            <p class="mt-4 text-lg font-semibold text-[#295b74]"><%= formatPrice(property) %></p>
          </div>
        </article>
      <% }); %>
    </div>

    <%- include('partials/pagination', { pagination, basePath: '/villas', querySuffix }) %>
  </section>
</main>

<%- include('partials/footer') %>
