    }

    function buildDetailConfig(key) {
      if (!currentModel) {
        return null;
      }

      const bestType = currentModel.byInvestmentType.slice().sort(function (a, b) { return b.averageROI - a.averageROI; })[0];
      const broadWinner = currentModel.byBroadType.slice().sort(function (a, b) { return b.averageROI - a.averageROI; })[0];
      const topFive = currentModel.items.slice(0, 5);

      if (key === 'totalProperties') {
        return {
          title: 'Detail: Total properties',
          copy: 'Ce KPI mesure combien de biens individuels sont analyses dans le portefeuille global, y compris chaque unite appartement et chaque villa.',
          metrics: [
            { label: 'Total assets', value: currentModel.totalProperties, copy: 'Nombre total de biens analyses.' },
            { label: 'Investment types', value: currentModel.byInvestmentType.length, copy: 'Nombre de typologies presentes.' },
            { label: 'Top family', value: broadWinner ? broadWinner.label : 'N/A', copy: 'Famille dominante par rendement.' }
          ],
          points: [
            'Chaque unite S+1, S+2 et S+3 est comptabilisee separément pour refléter la realite du portefeuille.',
            'Ce chiffre donne la profondeur de l analyse: plus il est large, plus la comparaison est fiable.',
            'La distribution des types plus bas montre comment ce total se repartit.'
          ]
        };
      }

      if (key === 'averageROI') {
        return {
          title: 'Detail: Average ROI',
          copy: 'Le ROI moyen compare le revenu locatif annuel estime au prix d acquisition de chaque bien, puis calcule une moyenne sur tout le portefeuille.',
          metrics: [
            { label: 'Average ROI', value: formatPercent(currentModel.averageROI), copy: 'Rendement moyen global.' },
            { label: 'Best type ROI', value: bestType ? formatPercent(bestType.averageROI) : 'N/A', copy: bestType ? bestType.label + ' est en tete.' : 'Pas de type gagnant.' },
            { label: 'Top property ROI', value: currentModel.bestProperty ? formatPercent(currentModel.bestProperty.roi) : 'N/A', copy: 'Meilleur rendement individuel.' }
          ],
          points: [
            'Si le ROI moyen monte, cela signifie que le portefeuille transforme mieux le prix d achat en revenu annuel.',
            'Le meilleur type de bien tire generalement ce KPI vers le haut.',
            'Ce KPI doit se lire avec le revenu moyen pour arbitrer entre rendement et volume de cash.'
          ]
        };
      }

      if (key === 'averageRevenue') {
        return {
          title: 'Detail: Average revenue',
          copy: 'Le revenu moyen montre combien un bien genere en moyenne par an selon les hypotheses de location appliquees aux villas et aux appartements.',
          metrics: [
            { label: 'Average annual revenue', value: formatCurrency(currentModel.averageAnnualRevenue), copy: 'Cash annuel moyen par bien.' },
            { label: 'Portfolio revenue', value: formatCurrency(currentModel.totalAnnualRevenue), copy: 'Cash annuel total du portefeuille.' },
            { label: 'Top property revenue', value: currentModel.bestProperty ? formatCurrency(currentModel.bestProperty.annualRevenue) : 'N/A', copy: 'Bien qui genere le plus.' }
          ],
          points: [
            'Ce KPI aide a comprendre le potentiel de cash-flow, independamment du prix d achat.',
            'Un revenu moyen eleve est interessant, mais il doit rester cohérent avec le ROI.',
            'Les villas peuvent tirer le revenu vers le haut, alors que certains appartements gardent un meilleur rendement.'
          ]
        };
      }

      if (key === 'bestPropertyType') {
        return {
          title: 'Detail: Best property type',
          copy: 'Ce KPI identifie la typologie la plus performante entre S+1, S+2, S+3 et villas en fonction du ROI moyen.',
          metrics: [
            { label: 'Winning type', value: bestType ? bestType.label : 'N/A', copy: 'Type de bien le plus performant.' },
            { label: 'Winning ROI', value: bestType ? formatPercent(bestType.averageROI) : 'N/A', copy: 'ROI moyen du type gagnant.' },
            { label: 'Winning revenue', value: bestType ? formatCurrency(bestType.averageAnnualRevenue) : 'N/A', copy: 'Revenu moyen du type gagnant.' }
          ],
          points: [
            'Ce KPI repond directement a la question: quel type de bien faut-il privilegier aujourd hui ?',
            'Le type gagnant offre le meilleur compromis entre ticket d entree et revenu annuel.',
            'La comparaison detaillee juste en dessous permet de voir les autres types en parallele.'
          ]
        };
      }

      if (key === 'portfolioRevenue') {
        return {
          title: 'Detail: Portfolio revenue',
          copy: 'Le revenu portefeuille additionne le revenu annuel estime de tous les biens analyses pour mesurer la puissance globale du parc immobilier.',
          metrics: [
            { label: 'Portfolio revenue', value: formatCurrency(currentModel.totalAnnualRevenue), copy: 'Somme de tous les revenus annuels.' },
            { label: 'Average revenue', value: formatCurrency(currentModel.averageAnnualRevenue), copy: 'Moyenne par bien.' },
            { label: '5Y projection', value: formatCurrency(currentModel.projection[currentModel.projection.length - 1].value), copy: 'Projection moyenne finale sur 5 ans.' }
          ],
          points: [
            'Ce KPI donne une vision business: combien le portefeuille peut produire sur une annee.',
            'Il aide a dimensionner la valeur economique totale du parc.',
            'La courbe de projection montre comment la base de valeur evolue dans le temps.'
          ]
        };
      }

      if (key === 'topProperty') {
        return {
          title: 'Detail: Top property',
          copy: 'Ce KPI met en avant le bien qui affiche le meilleur ROI sur l ensemble du portefeuille et montre pourquoi il ressort en tete.',
          metrics: [
            { label: 'Top property', value: currentModel.bestProperty ? currentModel.bestProperty.name : 'N/A', copy: 'Bien le plus performant.' },
            { label: 'Top ROI', value: currentModel.bestProperty ? formatPercent(currentModel.bestProperty.roi) : 'N/A', copy: 'Rendement de reference.' },
            { label: 'Top annual revenue', value: currentModel.bestProperty ? formatCurrency(currentModel.bestProperty.annualRevenue) : 'N/A', copy: 'Revenu annuel du meilleur bien.' }
          ],
          points: topFive.map(function (item, index) {
            return 'Top ' + (index + 1) + ': ' + item.name + ' | ' + item.investmentType + ' | ' + formatPercent(item.roi);
          })
        };
      }

      return null;
    }

    function buildDetailChartConfig(key) {
      if (!currentModel) {
        return null;
      }

      const topFive = currentModel.items.slice(0, 5);

      if (key === 'totalProperties') {
        return {
          label: 'Mini graphique',
          title: 'Repartition du portefeuille par type de bien',
          markup: buildSparkBars(currentModel.pie.map(function (item) { return item.value; }), '#5b8def'),
          explain: 'Ces barres montrent combien de biens existent dans chaque categorie du portefeuille. Plus une barre est haute, plus ce type est present dans le total affiche.'
        };
      }

      if (key === 'averageROI') {
        return {
          label: 'Mini graphique',
          title: 'Comparaison du ROI moyen par type',
          markup: buildSparkLine(currentModel.byInvestmentType.map(function (item) { return item.averageROI; }), '#5b8def', '#5b8def'),
          explain: 'Cette courbe compare le ROI moyen des types S+1, S+2, S+3 et Villa. Elle sert a voir quel type pousse le ROI global vers le haut ou vers le bas.'
        };
      }

      if (key === 'averageRevenue') {
        return {
          label: 'Mini graphique',
          title: 'Revenu annuel moyen par type de bien',
          markup: buildSparkBars(currentModel.byInvestmentType.map(function (item) { return item.averageAnnualRevenue; }), '#ff8f5a'),
          explain: 'Ces barres montrent le revenu annuel moyen genere par chaque type de bien. Elles permettent de comparer rapidement quel type apporte le plus de cash sur une annee.'
        };
      }

      if (key === 'bestPropertyType') {
        return {
          label: 'Mini graphique',
          title: 'Pourquoi ce type est le meilleur',
          markup: buildSparkBars(currentModel.byInvestmentType.map(function (item) { return item.averageROI; }), '#f3c45d'),
          explain: 'Ces barres comparent le ROI moyen des grands types d investissement. La barre la plus haute correspond au type qui devient le meilleur choix dans le KPI.'
        };
      }

      if (key === 'portfolioRevenue') {
        return {
          label: 'Mini graphique',
          title: 'Evolution projetee de la valeur moyenne sur 5 ans',
          markup: buildSparkLine(currentModel.projection.map(function (item) { return item.value; }), '#ec6a7b', '#ec6a7b'),
          explain: 'Cette courbe montre la projection de la valeur moyenne du portefeuille sur 5 ans. Elle aide a comprendre si la base patrimoniale prend de la valeur au fil du temps.'
        };
      }

      if (key === 'topProperty') {
        return {
          label: 'Mini graphique',
          title: 'ROI des 5 meilleures proprietes',
          markup: buildSparkLine(topFive.map(function (item) { return item.roi; }), '#8e67dd', '#8e67dd'),
          explain: 'Cette courbe montre le niveau de ROI des 5 meilleures proprietes. Elle permet de voir si le bien numero 1 est juste legerement meilleur ou tres au-dessus du reste.'
        };
      }

      return {
        label: 'Mini graphique',
        title: 'Lecture visuelle du KPI',
        markup: '',
        explain: 'Ce mini graphique montre la logique visuelle du KPI.'
      };
    }

    function openKpiDetail(key) {
      const detail = buildDetailConfig(key);
      if (!detail) {
        return;
      }
      const chartDetail = buildDetailChartConfig(key);

      detailTitleNode.textContent = detail.title;
      detailCopyNode.textContent = detail.copy;
      detailGridNode.innerHTML = detail.metrics.map(function (metric) {
        return '<div class="stats-detail-card">'
          + '<span>' + metric.label + '</span>'
          + '<strong>' + metric.value + '</strong>'
          + '<p>' + metric.copy + '</p>'
          + '</div>';
      }).join('');
      detailChartLabelNode.textContent = chartDetail && chartDetail.label ? chartDetail.label : 'Mini graphique';
      detailChartTitleNode.textContent = chartDetail && chartDetail.title ? chartDetail.title : 'Lecture visuelle du KPI';
      detailChartPreviewNode.innerHTML = chartDetail && chartDetail.markup ? chartDetail.markup : '';
      detailChartExplainNode.textContent = chartDetail && chartDetail.explain ? chartDetail.explain : 'Ce mini graphique montre la logique visuelle du KPI.';
      detailPointsNode.innerHTML = detail.points.map(function (point) {
        return '<div class="stats-detail-point">' + point + '</div>';
      }).join('');
      detailModalNode.classList.add('is-open');
      detailModalNode.setAttribute('aria-hidden', 'false');
    }

    function closeKpiDetail() {
      detailModalNode.classList.remove('is-open');
      detailModalNode.setAttribute('aria-hidden', 'true');
    }

    function renderSummary(summary) {
      summaryTitleNode.textContent = summary.title;
      summaryCopyNode.textContent = summary.copy;
      summaryPointsNode.innerHTML = summary.points.map(function (point) {
        return '<div class="stats-side-point">' + point + '</div>';
      }).join('');
    }

    function renderInsights(insights) {
      insightsNode.innerHTML = insights.map(function (insight) {
        return '<article class="stats-insight">'
          + '<span>Simple insight</span>'
          + '<p>' + insight + '</p>'
          + '</article>';
      }).join('');
    }

    function renderTable(items) {
      tableBodyNode.innerHTML = items.slice(0, 5).map(function (item) {
        return '<tr>'
          + '<td><strong>' + item.name + '</strong><br><span>' + item.id + '</span></td>'
          + '<td>' + item.investmentType + '</td>'
          + '<td>' + formatPercent(item.roi) + '</td>'
          + '<td>' + formatCurrency(item.annualRevenue) + '</td>'
          + '</tr>';
      }).join('');
    }

    function renderProjectionSummary(model) {
      const startValue = model.projection[0] ? model.projection[0].value / 1.05 : 0;
      const endValue = model.projection[model.projection.length - 1] ? model.projection[model.projection.length - 1].value : 0;
      const totalGrowth = startValue > 0 ? ((endValue - startValue) / startValue) : 0;

      projectionSummaryNode.innerHTML = [
        {
          label: 'Prix moyen de depart',
          value: formatCurrency(startValue),
          copy: 'Base actuelle moyenne estimee avant projection.'
        },
        {
          label: 'Prix moyen a 5 ans',
          value: formatCurrency(endValue),
          copy: 'Valeur moyenne theorique apres 5 ans de croissance.'
        },
        {
          label: 'Hausse totale',
          value: formatPercent(totalGrowth),
          copy: 'Progression cumulee entre aujourd hui et la 5e annee.'
        }
      ].map(function (item) {
        return '<div class="stats-projection-box">'
          + '<span>' + item.label + '</span>'
          + '<strong>' + item.value + '</strong>'
          + '<p>' + item.copy + '</p>'
          + '</div>';
      }).join('');

      projectionHelpNode.innerHTML = 'Comment lire cette courbe : nous prenons le prix moyen actuel du portefeuille comme point de depart, puis nous appliquons une croissance annuelle fixe de 5%. '
        + 'La courbe ne represente pas une prediction garantie, mais un scenario de lecture simple pour comprendre comment la valeur moyenne pourrait evoluer dans le temps.';
    }

    function render(items) {
      if (!items.length) {
        stateNode.textContent = 'Aucun bien disponible pour construire le dashboard.';
        stateNode.classList.remove('hidden');
        contentNode.classList.add('hidden');
        return;
      }

      const model = buildViewModel(items);
      currentModel = model;
      stateNode.classList.add('hidden');
      contentNode.classList.remove('hidden');
      renderKpis(model);
      renderSummary(createSummary(model));
      renderInsights(buildInsights(model));
      renderTable(model.items);
      renderProjectionSummary(model);
      drawGroupedChart(chartNodes.broadType, model.byBroadType, 'ROI moyen', 'averageROI', 'Revenu annuel moyen', 'averageAnnualRevenue');
      drawGroupedChart(chartNodes.investmentType, model.byInvestmentType, 'ROI moyen', 'averageROI', 'Revenu annuel moyen', 'averageAnnualRevenue');
      drawLineChart(chartNodes.projection, model.projection);
      drawPieChart(chartNodes.pie, model.pie);
    }

    window.addEventListener('resize', function () {
      if (!contentNode.classList.contains('hidden')) {
        render(normalizedPropertiesCache);
      }
    });

    detailCloseNode.addEventListener('click', closeKpiDetail);
    detailModalNode.addEventListener('click', function (event) {
      if (event.target === detailModalNode) {
        closeKpiDetail();
      }
    });
    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape' && detailModalNode.classList.contains('is-open')) {
        closeKpiDetail();
      }
    });

    fetch('/api/properties')
      .then(function (response) {
        if (!response.ok) throw new Error('HTTP ' + response.status);
        return response.json();
      })
      .then(function (payload) {
        const list = Array.isArray(payload) ? payload : (Array.isArray(payload.data) ? payload.data : payload.properties || []);
        normalizedPropertiesCache = normalizeProperties(list);
        render(normalizedPropertiesCache);
      })
      .catch(function () {
        stateNode.textContent = 'Impossible de charger les statistiques depuis /api/properties.';
        stateNode.classList.add('stats-state--error');
      });
  }());
</script>

<%- include('partials/footer') %>
