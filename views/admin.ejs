<%- include('partials/head', { title, bodyClass: 'admin-page' }) %>
<%- include('partials/navbar', { page: 'admin', properties }) %>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">

<main class="bg-gradient-to-b from-white via-brand-sand to-white text-brand-ink min-h-screen">
  <% const fallbackImage = '/assets/img/real-estate/property-exterior-3.webp'; %>
  <% const statusOptions = ['featured', 'for-sale', 'for-rent', 'new', 'hot', 'price-drop']; %>
  <% const isSale = viewMode === 'sale'; %>
  <% const isRent = viewMode === 'rent'; %>
  <% const isRequests = viewMode === 'requests'; %>
  <% const heroUpdatedFlag = typeof heroUpdated !== 'undefined' ? Boolean(heroUpdated) : false; %>
  <% const heroErrorFlag = typeof heroError !== 'undefined' ? Boolean(heroError) : false; %>
  <% const homeHeroImagePath = typeof homeHeroImage !== 'undefined' && homeHeroImage ? homeHeroImage : fallbackImage; %>
  <% const homeCfg = typeof homeSettings !== 'undefined' && homeSettings ? homeSettings : {}; %>
  <% const homeContentUpdatedFlag = typeof homeContentUpdated !== 'undefined' ? Boolean(homeContentUpdated) : false; %>

  <section class="py-10 bg-gradient-to-r from-white via-brand-sand to-white border-b border-brand-ink/5">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div>
        <p class="text-xs uppercase tracking-[0.25em] text-brand-ink/50">Tableau de bord</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-brand-ink">
          <% if (isRequests) { %>Demandes de contact<% } else { %><%= isSale ? 'Biens en Vente' : 'Biens en Location' %><% } %>
        </h1>
        <p class="text-brand-ink/70">
          <% if (isRequests) { %>Suivez et gérez les demandes reçues depuis les fiches biens.<% } else { %>Ajoutez un bien puis consultez la liste pour ce type uniquement.<% } %>
        </p>
      </div>
      <div class="text-sm text-brand-ink/70 flex flex-col sm:items-end">
        <span class="font-semibold text-brand-ink"><%= (properties || []).length %> biens actifs</span>
        <span class="text-brand-ink/60">Vente: <%= (saleProperties || []).length %> · Location: <%= (rentProperties || []).length %></span>
      </div>
    </div>
  </section>

  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 space-y-8">
      <section class="bg-white border border-brand-ink/10 rounded-3xl shadow-sm p-4 sm:p-5">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
          <nav class="flex flex-wrap items-center gap-2 text-sm">
            <a href="/admin/sale" class="rounded-full px-4 py-2 border <%= isSale ? 'bg-brand-ink text-white border-brand-ink' : 'bg-white text-brand-ink/80 border-brand-ink/15 hover:border-brand-ink/30' %>">Vente</a>
            <a href="/admin/rent" class="rounded-full px-4 py-2 border <%= isRent ? 'bg-brand-ink text-white border-brand-ink' : 'bg-white text-brand-ink/80 border-brand-ink/15 hover:border-brand-ink/30' %>">Location</a>
            <a href="/admin/requests" class="rounded-full px-4 py-2 border <%= isRequests ? 'bg-brand-ink text-white border-brand-ink' : 'bg-white text-brand-ink/80 border-brand-ink/15 hover:border-brand-ink/30' %>">Demandes</a>
          </nav>
          <% if (!isRequests) { %>
            <div class="flex flex-wrap gap-2">
              <button id="showFormBtn" type="button" class="tw-btn-ghost text-sm">Ajouter un bien</button>
              <a href="#listings" class="tw-btn-primary text-sm">Gerer les annonces</a>
            </div>
          <% } %>
        </div>
      </section>

      <section class="bg-white border border-brand-ink/10 rounded-3xl shadow-sm p-5 space-y-4">
        <div class="flex items-center justify-between flex-wrap gap-2">
          <div>
            <p class="text-xs uppercase tracking-[0.25em] text-brand-ink/50">Accueil</p>
            <h2 class="text-xl font-semibold text-brand-ink">Image principale</h2>
          </div>
          <span class="text-xs px-3 py-1 rounded-full bg-brand-sand text-brand-ink/80">Hero page d'accueil</span>
        </div>

        <% if (heroUpdatedFlag) { %>
          <div class="rounded-xl border border-emerald-200 bg-emerald-50 text-emerald-800 px-4 py-2 text-sm">
            Image d'accueil mise a jour avec succes.
          </div>
        <% } %>

        <% if (heroErrorFlag) { %>
          <div class="rounded-xl border border-red-200 bg-red-50 text-red-700 px-4 py-2 text-sm">
            Aucune image recue. Veuillez choisir un fichier puis reessayer.
          </div>
        <% } %>
        <% if (homeContentUpdatedFlag) { %>
          <div class="rounded-xl border border-emerald-200 bg-emerald-50 text-emerald-800 px-4 py-2 text-sm">
            Contenu de la page d'accueil mis a jour.
          </div>
        <% } %>

        <div class="grid md:grid-cols-[minmax(0,1fr)_minmax(0,1.2fr)] gap-4">
          <div class="space-y-2">
            <p class="text-sm text-brand-ink/70">Image actuelle</p>
            <img src="<%= homeHeroImagePath %>" alt="Image accueil actuelle" class="h-40 w-full rounded-2xl object-cover border border-brand-ink/10">
            <p class="text-xs text-brand-ink/60 break-all"><%= homeHeroImagePath %></p>
          </div>

          <form action="/admin/settings/home-hero" method="POST" enctype="multipart/form-data" class="space-y-3">
            <input type="hidden" name="redirectMode" value="<%= viewMode %>">
            <div>
              <label for="homeHeroFile" class="text-sm text-brand-ink/80">Nouvelle image accueil</label>
              <input id="homeHeroFile" name="homeHeroFile" type="file" accept="image/*" required class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2">
              <p class="mt-1 text-xs text-brand-ink/60">Formats image, max 10 Mo.</p>
            </div>
            <button type="submit" class="tw-btn-primary text-sm">Mettre a jour l'image d'accueil</button>
          </form>
        </div>

        <form action="/admin/settings/home-content" method="POST" class="rounded-2xl border border-brand-ink/10 bg-brand-sand/30 p-4 space-y-4">
          <input type="hidden" name="redirectMode" value="<%= viewMode %>">
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label class="text-sm text-brand-ink/80">Badge accueil</label>
              <input name="heroEyebrow" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" value="<%= homeCfg.heroEyebrow || 'Kelibia, Tunisie' %>">
            </div>
            <div>
              <label class="text-sm text-brand-ink/80">CTA texte</label>
              <input name="heroCtaLabel" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" value="<%= homeCfg.heroCtaLabel || 'Explorer les biens' %>">
            </div>
            <div class="md:col-span-2">
              <label class="text-sm text-brand-ink/80">Titre principal accueil</label>
              <input name="heroTitle" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" value="<%= homeCfg.heroTitle || 'Trouvez votre bien a Kelibia' %>">
            </div>
            <div class="md:col-span-2">
              <label class="text-sm text-brand-ink/80">Sous-titre accueil</label>
              <textarea name="heroSubtitle" rows="2" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2"><%= homeCfg.heroSubtitle || "Residences et villas pensees pour le confort, l'emplacement et la valeur." %></textarea>
            </div>
            <div>
              <label class="text-sm text-brand-ink/80">Lien du bouton CTA</label>
              <input name="heroCtaHref" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" value="<%= homeCfg.heroCtaHref || '/properties?page=1' %>">
            </div>
            <div>
              <label class="text-sm text-brand-ink/80">Microcopy (separee par virgules)</label>
              <input name="heroMicrocopy" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" value="<%= Array.isArray(homeCfg.heroMicrocopy) ? homeCfg.heroMicrocopy.join(', ') : 'Front de mer, Centre-ville, Quartiers calmes' %>">
            </div>
            <div>
              <label class="text-sm text-brand-ink/80">Texte scene (ligne 1/2 avec \n)</label>
              <input name="sceneCaptionTitle" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" value="<%= homeCfg.sceneCaptionTitle || 'Rylion\\nImmobilière' %>">
            </div>
            <div>
              <label class="text-sm text-brand-ink/80">Sous-texte scene</label>
              <input name="sceneCaptionSubtitle" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" value="<%= homeCfg.sceneCaptionSubtitle || 'Art de vivre cotier' %>">
            </div>
            <div>
              <label class="text-sm text-brand-ink/80">Image scene gauche (URL /assets ou /uploads)</label>
              <input name="sceneImageSmallA" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" value="<%= homeCfg.sceneImageSmallA || '/assets/img/real-estate/property-exterior-2.webp' %>">
            </div>
            <div>
              <label class="text-sm text-brand-ink/80">Image scene droite (URL /assets ou /uploads)</label>
              <input name="sceneImageSmallB" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" value="<%= homeCfg.sceneImageSmallB || '/assets/img/real-estate/property-interior-8.webp' %>">
            </div>
          </div>
          <button type="submit" class="tw-btn-primary text-sm">Enregistrer le contenu de l'accueil</button>
        </form>
      </section>

      <div class="space-y-10">
        <% if (!isRequests) { %>
        <section id="form-current" class="hidden bg-white border border-brand-ink/10 rounded-3xl shadow-lg p-6 space-y-5">
          <div class="flex items-center justify-between flex-wrap gap-3">
            <div>
              <p class="text-xs uppercase tracking-[0.25em] text-brand-ink/50"><%= isSale ? 'Vente' : 'Location' %></p>
              <h3 class="text-2xl font-semibold text-brand-ink"><%= isSale ? 'Ajouter un bien à la vente' : 'Ajouter un bien en location' %></h3>
            </div>
            <span class="px-3 py-1 rounded-full text-xs bg-brand-sand text-brand-ink/80">Listing Type : <%= isSale ? 'Vente' : 'Location' %></span>
          </div>
          <div class="flex justify-end">
            <button id="hideFormBtn" type="button" class="tw-btn-ghost text-xs">Fermer le formulaire</button>
          </div>
          <form action="/admin" method="POST" enctype="multipart/form-data" class="space-y-5">
            <input type="hidden" name="listingType" value="<%= isSale ? 'sale' : 'rent' %>">
            <div class="grid md:grid-cols-2 gap-4">
              <div class="md:col-span-2">
                <label class="text-sm text-brand-ink/80">Titre</label>
                <input name="title" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" placeholder="<%= isSale ? 'Maison moderne' : 'Appartement lumineux' %>">
              </div>
              <input id="refInput" name="ref" type="hidden">

              <div class="md:col-span-2">
                <label class="text-sm text-brand-ink/80">Description</label>
                <textarea name="headline" rows="3" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" placeholder="<%= isSale ? 'Finitions haut de gamme' : 'Proche centre-ville, equipe' %>"></textarea>
              </div>
            </div>
            <div class="grid md:grid-cols-3 gap-4">
              <div id="priceFieldWrapper">
                <label class="text-sm text-brand-ink/80"><%= isSale ? 'Prix' : 'Loyer' %></label>
                <input id="priceInput" name="price" type="number" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" placeholder="<%= isSale ? '450000' : '1200' %>">
              </div>
              <div>
                <label class="text-sm text-brand-ink/80">Statuts</label>
                <input id="statusValue" name="status" type="hidden" required>
                <input id="statusInput" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" placeholder="<%= isSale ? 'A louer, A vendre' : 'A louer, A vendre' %>">
                <div id="statusTags" class="mt-2 flex flex-wrap gap-2"></div>
              </div>
              <div id="paymentTermWrapper">
                <label class="text-sm text-brand-ink/80">Terme de paiement</label>
                <select id="paymentTermInput" name="paymentTerm" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2">
                  <option value="mois" selected>Par mois</option>
                  <option value="jour">Par jour</option>
                </select>
              </div>
            </div>
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label class="text-sm text-brand-ink/80">Type de bien</label>
                <select id="propertyTypeSelect" name="type" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" required>
                  <option value="" disabled selected>Choisir un type</option>
                  <option value="Residence">Residence</option>
                  <option value="Maison">Maison</option>
                  <option value="Maison de ville">Maison de ville</option>
                  <option value="Villa">Villa</option>
                  <option value="Appartement">Appartement</option>
                  <option value="Studio">Studio</option>
                  <option value="Duplex">Duplex</option>
                  <option value="Loft">Loft</option>
                  <option value="Rez-de-chaussee">Rez-de-chaussee</option>
                  <option value="Terrain">Terrain</option>
                  <option value="Local commercial">Local commercial</option>
                  <option value="Bureau">Bureau</option>
                  <option value="Entrepot">Entrepot</option>
                  <option value="Immeuble">Immeuble</option>
                  <option value="Ferme">Ferme</option>
                  <option value="Garage">Garage</option>
                  <option value="Autre">Autre</option>
                </select>
              </div>
              <div>
                <label class="text-sm text-brand-ink/80">Adresse / Ville</label>
                <input id="addressInput" name="address" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" placeholder="45 Rue Exemple" required>
                <input id="cityInput" name="city" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" placeholder="Paris" required>
              </div>
              <div class="md:col-span-2">
                <label class="text-sm text-brand-ink/80">Google Maps URL</label>
                <input id="googleMapsUrl" name="googleMapsUrl" type="url" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" placeholder="https://maps.google.com/?q=" required>
                <input id="mapLat" name="mapLat" type="hidden">
                <input id="mapLng" name="mapLng" type="hidden">
                <div class="mt-4">
                  <div class="text-xs text-brand-ink/60 mb-2">Rechercher une adresse exacte</div>
                  <div class="flex flex-col sm:flex-row gap-2">
                    <input id="mapSearchInput" type="search" class="w-full rounded-xl border border-brand-ink/10 px-3 py-2" placeholder="Ex: 10 Rue de Marseille, Tunis">
                    <button id="mapSearchButton" type="button" class="tw-btn-ghost whitespace-nowrap">Rechercher</button>
                  </div>
                  <div id="mapSearchStatus" class="mt-2 text-xs text-brand-ink/60 hidden"></div>
                  <div id="mapSearchResults" class="mt-3 space-y-2"></div>
                </div>
                <div class="mt-4">
                  <div class="text-xs text-brand-ink/60 mb-2">Choisir l'emplacement sur la carte</div>
                  <div id="mapPicker" class="h-96 w-full rounded-xl border border-brand-ink/10"></div>
                </div>
              </div>
            </div>
            <div id="residenceAutoSection" class="hidden rounded-2xl border border-brand-ink/10 bg-brand-sand/30 p-4 space-y-4">
              <div class="grid md:grid-cols-2 gap-4">
                <div>
                  <label class="text-sm text-brand-ink/80">Nombre d'appartements</label>
                  <input id="apartmentCountInput" name="apartmentCount" type="number" min="4" step="1" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" placeholder="8">
                </div>
                <div>
                  <label class="text-sm text-brand-ink/80">Prix par m2 (TND)</label>
                  <input id="pricePerSquareMeterInput" name="pricePerSquareMeter" type="number" min="1" step="1" value="1600" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" placeholder="1600">
                </div>
                <div class="md:col-span-2 rounded-xl border border-brand-ink/10 bg-white px-4 py-3 text-sm text-brand-ink/70">
                  Pour une residence, on garde les donnees existantes tant que vous ne changez pas le nombre d'appartements ou le prix par m2.
                </div>
              </div>
            </div>
            <div id="standardPropertyFields" class="grid md:grid-cols-3 gap-4">
              <div>
                <label class="text-sm text-brand-ink/80">Chambres</label>
                <input id="bedroomsInput" name="bedrooms" type="number" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" placeholder="3" required>
              </div>
              <div>
                <label class="text-sm text-brand-ink/80">Salles de bain</label>
                <input id="bathroomsInput" name="bathrooms" type="number" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" placeholder="2" required>
              </div>
              <div>
                <label class="text-sm text-brand-ink/80">Surface (m²)</label>
                <input id="areaInput" name="area" type="number" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" placeholder="120" required>
              </div>
            </div>
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label class="text-sm text-brand-ink/80">Vignette (upload)</label>
                <label for="thumbnailFile" id="thumbnailDrop" class="mt-1 flex flex-col items-center justify-center border-2 border-dashed border-brand-ink/20 rounded-xl bg-brand-sand/40 px-4 py-6 text-center cursor-pointer">
                  <i class="bi bi-cloud-arrow-up text-2xl text-brand-ink/60"></i>
                  <p class="text-sm text-brand-ink/70 m-0">Glissez-déposez ou cliquez pour choisir</p>
                  <p class="text-[11px] text-brand-ink/60 m-0">Formats image, max 10 Mo</p>
                  <input name="thumbnailFile" id="thumbnailFile" type="file" accept="image/*" class="hidden" required>
                </label>
                <div id="thumbnailPreview" class="mt-2 hidden">
                  <p class="text-xs text-brand-ink/60 mb-1">Apercu vignette</p>
                  <div class="relative">
                    <img class="h-28 w-full rounded-xl object-cover border border-brand-ink/10">
                    <button type="button" id="thumbnailRemove" class="absolute -top-2 -right-2 h-6 w-6 rounded-md bg-red-600 text-white flex items-center justify-center shadow">
                      <i class="bi bi-trash text-[10px]"></i>
                    </button>
                  </div>
                </div>
              </div>
              <div>
                <label class="text-sm text-brand-ink/80">Galerie (upload multiple)</label>
                <label for="galleryFiles" id="galleryDrop" class="mt-1 flex flex-col items-center justify-center border-2 border-dashed border-brand-ink/20 rounded-xl bg-brand-sand/40 px-4 py-6 text-center cursor-pointer">
                  <i class="bi bi-images text-2xl text-brand-ink/60"></i>
                  <p class="text-sm text-brand-ink/70 m-0">Glissez plusieurs images ou cliquez</p>
                  <p class="text-[11px] text-brand-ink/60 m-0">Jusqu'à 10 images</p>
                  <input name="galleryFiles" id="galleryFiles" type="file" multiple accept="image/*" class="hidden" required>
                </label>
                <div id="galleryPreview" class="mt-2 grid grid-cols-3 gap-2 hidden"></div>
              </div>
            </div>
            <div>
              <label class="text-sm text-brand-ink/80">Equipements</label>
              <input id="amenitiesValue" name="amenities" type="hidden" >
              <input id="amenitiesInput" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2" placeholder="<%= isSale ? 'Piscine, Terrasse, Parking' : 'Meuble, Balcon, Parking' %>" required>
              <div id="amenitiesTags" class="mt-2 flex flex-wrap gap-2"></div>
            </div>
            <div class="pt-2">
              <button type="submit" class="tw-btn-primary w-full rounded-lg flex items-center justify-center"><%= isSale ? 'Publier (Vente)' : 'Publier (Location)' %></button>
            </div>
          </form>
        </section>

        <section id="listings" class="space-y-6 bg-white border border-brand-ink/10 rounded-3xl shadow-lg p-6">
          <div class="flex items-center justify-between flex-wrap gap-3">
            <div>
              <p class="text-xs uppercase tracking-[0.25em] text-brand-ink/50">Biens existants</p>
              <h3 class="text-2xl font-semibold text-brand-ink"><%= isSale ? 'Vente' : 'Location' %></h3>
            </div>
            <span class="text-sm text-brand-ink/60"><%= isSale ? (saleProperties || []).length : (rentProperties || []).length %> annonces</span>
          </div>
          <div class="grid gap-3 md:grid-cols-[minmax(0,1.5fr)_minmax(0,1fr)_minmax(0,1fr)]">
            <div>
              <label for="adminSearch" class="text-sm text-brand-ink/80">Recherche rapide</label>
              <input
                id="adminSearch"
                type="search"
                class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2"
                placeholder="Titre, adresse, ville ou reference"
              >
            </div>
            <div>
              <label for="adminStatusFilter" class="text-sm text-brand-ink/80">Statut</label>
              <select id="adminStatusFilter" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2">
                <option value="">Tous les statuts</option>
                <% statusOptions.forEach(function(statusOption){ %>
                  <option value="<%= statusOption %>"><%= statusMeta[statusOption]?.label || statusOption %></option>
                <% }); %>
              </select>
            </div>
            <div>
              <label for="adminSort" class="text-sm text-brand-ink/80">Tri</label>
              <select id="adminSort" class="w-full mt-1 rounded-xl border border-brand-ink/10 px-3 py-2">
                <option value="recent">Plus recent</option>
                <option value="price-desc">Prix decroissant</option>
                <option value="price-asc">Prix croissant</option>
                <option value="title-asc">Titre A-Z</option>
              </select>
            </div>
          </div>
          <div class="grid md:grid-cols-3 gap-6" id="list-current">
            <% (isSale ? saleProperties : rentProperties || []).forEach(function(p){ const primaryStatus = (p.status || [])[0] || ''; const statusLabel = statusMeta[primaryStatus]?.label || primaryStatus || 'Annonce'; %>
              <article class="property-card rounded-2xl overflow-hidden bg-white border border-brand-ink/10 shadow hover:-translate-y-1 transition"
                   data-title="<%= (p.title || '').toLowerCase() %>"
                   data-city="<%= (p.city || '').toLowerCase() %>"
                   data-address="<%= (p.address || '').toLowerCase() %>"
                   data-status="<%= primaryStatus %>"
                   data-ref="<%= (p.ref || p.id || '').toLowerCase() %>"
                   data-price="<%= p.price || 0 %>"
                   data-created="<%= p.createdAt || '' %>">
                <div class="relative">
                  <img src="<%= p.thumbnail || fallbackImage %>" class="w-full h-48 object-cover" alt="<%= p.title %>">
                  <div class="absolute top-3 left-3 flex flex-wrap gap-1">
                    <span class="px-3 py-1 rounded-full text-[11px] font-semibold bg-brand-gold text-brand-ink"><%= statusLabel %></span>
                    <span class="px-3 py-1 rounded-full text-[11px] font-semibold bg-brand-sand text-brand-ink/80"><%= p.listingType === 'rent' ? 'A louer' : 'A vendre' %></span>
                  </div>
                  <div class="absolute bottom-3 right-3 px-3 py-1 rounded-full text-xs bg-white/90 text-brand-ink shadow"><%= formatPrice(p) %></div>
                </div>
                <div class="p-4 space-y-2">
                  <h3 class="text-lg font-semibold text-brand-ink"><a href="/property/<%= p.id %>"><%= p.title %></a></h3>
                  <p class="text-xs text-brand-ink/60 m-0">REF: <%= p.ref || p.id %></p>
                  <p class="text-sm text-brand-ink/70 flex items-center gap-2 m-0"><i class="bi bi-geo-alt"></i><%= p.city || p.address || '' %></p>
                  <% const desc = (p.headline || p.priceNote || '').trim(); %>
                  <p class="text-sm text-brand-ink/70 m-0"><%= desc.length > 140 ? desc.slice(0, 140) + '...' : desc %></p>
                  <div class="flex items-center gap-3 text-sm text-brand-ink/80 flex-wrap">
                    <% if (p.type === 'Residence' && p.availableTypes && p.availableTypes.length) { %>
                      <span class="flex items-center gap-1"><i class="bi bi-building"></i> <%= p.apartmentCount || 0 %> appartements</span>
                      <span class="flex items-center gap-1"><i class="bi bi-diagram-3"></i> <%= p.availableTypes.join(' / ') %></span>
                      <span class="flex items-center gap-1"><i class="bi bi-rulers"></i> <%= p.surfaceRange || `${formatNumber(p.area || p.surface || 0)} m2` %></span>
                    <% } else { %>
                      <span class="flex items-center gap-1"><i class="bi bi-house"></i> <%= p.bedrooms %> ch</span>
                      <span class="flex items-center gap-1"><i class="bi bi-droplet"></i> <%= p.bathrooms %> sdb</span>
                      <span class="flex items-center gap-1"><i class="bi bi-rulers"></i> <%= formatNumber(p.area) %> m2</span>
                    <% } %>
                  </div>
                  <div class="flex items-center justify-between pt-2">
                    <div class="flex items-center gap-2 text-sm text-brand-ink/70">
                      <img src="<%= p.agent?.avatar || '/assets/img/real-estate/agent-1.webp' %>" class="h-8 w-8 rounded-full object-cover" alt="Agent">
                      <div>
                        <p class="m-0 text-brand-ink text-sm"><%= p.agent?.name || 'Equipe interne' %></p>
                        <p class="m-0 text-xs text-brand-ink/70"><%= p.agent?.company || 'Rylion Immobilière' %></p>
                      </div>
                    </div>
                    <a href="/property/<%= p.id %>" class="tw-btn-ghost text-xs">Details</a>
                  </div>
                  <div class="grid grid-cols-3 gap-2 pt-3 border-t border-brand-ink/10">
                    <a href="/admin/edit/<%= p.id %>" class="tw-btn-primary text-xs text-center">Modifier tout</a>
                    <a href="/admin/edit/<%= p.id %>#media-files" class="tw-btn-ghost text-xs text-center">Photos</a>
                    <form action="/admin/delete" method="POST">
                      <input type="hidden" name="id" value="<%= p.id %>">
                      <button type="submit" class="tw-btn-primary text-xs w-full bg-red-600 hover:bg-red-700 border-red-700">Supprimer</button>
                    </form>
                  </div>
                </div>
              </article>
            <% }); %>
          </div>
          <div id="adminListEmpty" class="hidden rounded-2xl border border-dashed border-brand-ink/15 bg-brand-sand/30 p-6 text-center text-brand-ink/70">
            Aucun bien ne correspond a votre recherche.
          </div>
        </section>
        <% } else { %>
          <section class="bg-white border border-brand-ink/10 rounded-3xl shadow-lg p-6 space-y-4">
            <div class="flex items-center justify-between flex-wrap gap-2">
              <div>
                <p class="text-xs uppercase tracking-[0.25em] text-brand-ink/50">Demandes</p>
                <h3 class="text-2xl font-semibold text-brand-ink">Demandes de contact reçues</h3>
              </div>
              <span class="px-3 py-1 rounded-full text-xs bg-brand-sand text-brand-ink/80"><%= (requests || []).length %> reçues</span>
            </div>
            <div class="overflow-auto">
              <table class="min-w-full text-sm text-brand-ink">
                <thead>
                  <tr class="text-left text-brand-ink/70 border-b border-brand-ink/10">
                    <th class="py-2 pr-3">Date</th>
                    <th class="py-2 pr-3">Nom</th>
                    <th class="py-2 pr-3">Contact</th>
                    <th class="py-2 pr-3">Bien</th>
                    <th class="py-2 pr-3">Message</th>
                  </tr>
                </thead>
                <tbody>
                  <% (requests || []).slice().reverse().forEach(function(req){ %>
                    <tr class="border-b border-brand-ink/10 align-top">
                      <td class="py-2 pr-3 whitespace-nowrap"><%= new Date(req.createdAt).toLocaleString('fr-FR') %></td>
                      <td class="py-2 pr-3 font-semibold"><%= req.name %></td>
                      <td class="py-2 pr-3 text-brand-ink/70 whitespace-nowrap">
                        <div><%= req.email || '—' %></div>
                        <div><%= req.phone || '—' %></div>
                      </td>
                      <td class="py-2 pr-3 whitespace-nowrap">
                        <div class="flex items-center gap-2">
                          <img src="<%= req.propertyImage || fallbackImage %>" class="h-10 w-10 rounded-md object-cover" alt="Bien">
                          <div>
                            <div class="font-semibold text-brand-ink text-xs"><%= req.propertyTitle %></div>
                            <a href="/property/<%= req.propertyId %>" class="text-brand-ink/70 hover:text-brand-ink text-xs">Voir</a>
                          </div>
                        </div>
                      </td>
                      <td class="py-2 pr-3 text-brand-ink/80"><%= req.message || 'Pas de message' %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </section>

          <section class="bg-white border border-brand-ink/10 rounded-3xl shadow-lg p-6 space-y-4">
            <div class="flex items-center justify-between flex-wrap gap-2">
              <div>
                <p class="text-xs uppercase tracking-[0.25em] text-brand-ink/50">Proprietaires</p>
                <h3 class="text-2xl font-semibold text-brand-ink">Demandes de depot de biens</h3>
              </div>
              <span class="px-3 py-1 rounded-full text-xs bg-brand-sand text-brand-ink/80"><%= (ownerRequests || []).length %> recues</span>
            </div>
            <div class="overflow-auto">
              <table class="min-w-full text-sm text-brand-ink">
                <thead>
                  <tr class="text-left text-brand-ink/70 border-b border-brand-ink/10">
                    <th class="py-2 pr-3">Date</th>
                    <th class="py-2 pr-3">Nom</th>
                    <th class="py-2 pr-3">Contact</th>
                    <th class="py-2 pr-3">Type</th>
                    <th class="py-2 pr-3">Adresse</th>
                    <th class="py-2 pr-3">Budget</th>
                    <th class="py-2 pr-3">Message</th>
                  </tr>
                </thead>
                <tbody>
                  <% (ownerRequests || []).slice().reverse().forEach(function(req){ %>
                    <tr class="border-b border-brand-ink/10 align-top">
                      <td class="py-2 pr-3 whitespace-nowrap"><%= new Date(req.createdAt).toLocaleString('fr-FR') %></td>
                      <td class="py-2 pr-3 font-semibold"><%= req.name %></td>
                      <td class="py-2 pr-3 text-brand-ink/70 whitespace-nowrap">
                        <div><%= req.email || '-' %></div>
                        <div><%= req.phone || '-' %></div>
                      </td>
                      <td class="py-2 pr-3 whitespace-nowrap"><%= req.listingType === 'rent' ? 'Location' : 'Vente' %></td>
                      <td class="py-2 pr-3"><%= [req.address, req.city].filter(Boolean).join(', ') || '-' %></td>
                      <td class="py-2 pr-3 whitespace-nowrap"><%= req.price ? formatNumber(req.price) + ' TND' : '-' %></td>
                      <td class="py-2 pr-3 text-brand-ink/80"><%= req.message || 'Pas de message' %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </section>
        <% } %>
      </div>
    </div>
  </section>
</main>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<%- include('partials/footer') %>

<script>
  (function () {
    const refInput = document.getElementById('refInput');
    if (refInput) {
      const rand = Math.floor(1000 + Math.random() * 9000);
      refInput.value = `${rand}`;
    }

    const statusInput = document.getElementById('statusInput');
    const statusValue = document.getElementById('statusValue');
    const statusTags = document.getElementById('statusTags');
    if (statusInput && statusValue && statusTags) {
      const tags = [];

      function syncTags() {
        statusValue.value = tags.join(',');
      }

      function renderTag(tag) {
        const chip = document.createElement('span');
        chip.className = 'inline-flex items-center gap-2 rounded-full bg-brand-sand px-3 py-1 text-xs text-brand-ink/80';
        chip.textContent = tag;
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'text-brand-ink/60 hover:text-brand-ink';
        btn.textContent = 'x';
        btn.addEventListener('click', () => {
          const index = tags.indexOf(tag);
          if (index > -1) tags.splice(index, 1);
          chip.remove();
          syncTags();
        });
        chip.appendChild(btn);
        statusTags.appendChild(chip);
      }

      function addTag(raw) {
        const tag = raw.trim().replace(/,+$/, '');
        if (!tag || tags.includes(tag)) return;
        tags.push(tag);
        renderTag(tag);
        syncTags();
      }

      statusInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ',') {
          e.preventDefault();
          addTag(statusInput.value);
          statusInput.value = '';
        }
      });

      statusInput.addEventListener('blur', () => {
        if (statusInput.value.trim()) {
          addTag(statusInput.value);
          statusInput.value = '';
        }
      });
    }

    const amenitiesInput = document.getElementById('amenitiesInput');
    const amenitiesValue = document.getElementById('amenitiesValue');
    const amenitiesTags = document.getElementById('amenitiesTags');
    if (amenitiesInput && amenitiesValue && amenitiesTags) {
      const tags = [];

      function syncAmenities() {
        amenitiesValue.value = tags.join(',');
      }

      function renderAmenity(tag) {
        const chip = document.createElement('span');
        chip.className = 'inline-flex items-center gap-2 rounded-full bg-brand-sand px-3 py-1 text-xs text-brand-ink/80';
        chip.textContent = tag;
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'text-brand-ink/60 hover:text-brand-ink';
        btn.textContent = 'x';
        btn.addEventListener('click', () => {
          const index = tags.indexOf(tag);
          if (index > -1) tags.splice(index, 1);
          chip.remove();
          syncAmenities();
        });
        chip.appendChild(btn);
        amenitiesTags.appendChild(chip);
      }

      function addAmenity(raw) {
        const tag = raw.trim().replace(/,+$/, '');
        if (!tag || tags.includes(tag)) return;
        tags.push(tag);
        renderAmenity(tag);
        syncAmenities();
      }

      amenitiesInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ',') {
          e.preventDefault();
          addAmenity(amenitiesInput.value);
          amenitiesInput.value = '';
        }
      });

      amenitiesInput.addEventListener('blur', () => {
        if (amenitiesInput.value.trim()) {
          addAmenity(amenitiesInput.value);
          amenitiesInput.value = '';
        }
      });
    }

    const mapsInput = document.getElementById('googleMapsUrl');
    const propertyTypeSelect = document.getElementById('propertyTypeSelect');
    const apartmentCountInput = document.getElementById('apartmentCountInput');
    const pricePerSquareMeterInput = document.getElementById('pricePerSquareMeterInput');
    const residenceAutoSection = document.getElementById('residenceAutoSection');
    const standardPropertyFields = document.getElementById('standardPropertyFields');
    const bedroomsInput = document.getElementById('bedroomsInput');
    const bathroomsInput = document.getElementById('bathroomsInput');
    const areaInput = document.getElementById('areaInput');
    const priceInput = document.getElementById('priceInput');
    const priceFieldWrapper = document.getElementById('priceFieldWrapper');
    const paymentTermInput = document.getElementById('paymentTermInput');
    const paymentTermWrapper = document.getElementById('paymentTermWrapper');
    const addressInput = document.getElementById('addressInput');
    const cityInput = document.getElementById('cityInput');
    const mapLat = document.getElementById('mapLat');
    const mapLng = document.getElementById('mapLng');
    const mapPicker = document.getElementById('mapPicker');
    const mapSearchInput = document.getElementById('mapSearchInput');
    const mapSearchButton = document.getElementById('mapSearchButton');
    const mapSearchResults = document.getElementById('mapSearchResults');
    const mapSearchStatus = document.getElementById('mapSearchStatus');
    const adminForm = document.querySelector('form[action="/admin"]');

    function syncResidenceFormMode() {
      const isResidence = propertyTypeSelect && propertyTypeSelect.value === 'Residence';
      if (residenceAutoSection) {
        residenceAutoSection.classList.toggle('hidden', !isResidence);
      }
      if (standardPropertyFields) {
        standardPropertyFields.classList.toggle('hidden', isResidence);
      }
      if (priceFieldWrapper) {
        priceFieldWrapper.classList.toggle('opacity-70', isResidence);
      }
      if (paymentTermWrapper) {
        paymentTermWrapper.classList.toggle('opacity-70', isResidence);
      }
      if (bedroomsInput) {
        bedroomsInput.required = !isResidence;
        bedroomsInput.disabled = isResidence;
      }
      if (bathroomsInput) {
        bathroomsInput.required = !isResidence;
        bathroomsInput.disabled = isResidence;
      }
      if (areaInput) {
        areaInput.required = !isResidence;
        areaInput.disabled = isResidence;
      }
      if (apartmentCountInput) {
        apartmentCountInput.required = isResidence;
        apartmentCountInput.disabled = !isResidence;
        if (!apartmentCountInput.value && isResidence) {
          apartmentCountInput.value = '8';
        }
      }
      if (pricePerSquareMeterInput) {
        pricePerSquareMeterInput.required = isResidence;
        pricePerSquareMeterInput.disabled = !isResidence;
        if (!pricePerSquareMeterInput.value && isResidence) {
          pricePerSquareMeterInput.value = '1600';
        }
      }
      if (priceInput) {
        priceInput.readOnly = isResidence;
      }
      if (paymentTermInput) {
        paymentTermInput.disabled = isResidence;
        if (isResidence) paymentTermInput.value = '';
      }
    }

    if (propertyTypeSelect) {
      propertyTypeSelect.addEventListener('change', syncResidenceFormMode);
      syncResidenceFormMode();
    }
    if (mapPicker && window.L) {
      const map = L.map(mapPicker).setView([36.8065, 10.1815], 12);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; OpenStreetMap contributors'
      }).addTo(map);

      let marker = null;
      function setMarker(lat, lng) {
        if (!marker) {
          marker = L.marker([lat, lng]).addTo(map);
        } else {
          marker.setLatLng([lat, lng]);
        }
        mapLat.value = lat.toFixed(6);
        mapLng.value = lng.toFixed(6);
        if (mapsInput) {
          mapsInput.value = `https://www.google.com/maps?q=${lat},${lng}`;
        }
      }

      function updateAddressFields(address) {
        if (!address) return;
        const streetParts = [
          address.house_number,
          address.road || address.pedestrian || address.footway || address.residential || address.path
        ].filter(Boolean);
        const fallbackStreet = [
          address.suburb,
          address.neighbourhood,
          address.hamlet,
          address.quarter
        ].filter(Boolean);
        const cityValue = address.city || address.town || address.village || address.municipality || address.county || '';

        if (addressInput) {
          const nextAddress = streetParts.join(' ').trim() || fallbackStreet.join(', ').trim() || addressInput.value;
          if (nextAddress) addressInput.value = nextAddress;
        }

        if (cityInput && cityValue) {
          cityInput.value = cityValue;
        }
      }

      async function reverseGeocode(lat, lng) {
        try {
          const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${encodeURIComponent(lat)}&lon=${encodeURIComponent(lng)}`, {
            headers: {
              Accept: 'application/json'
            }
          });
          if (!response.ok) return;
          const result = await response.json();
          updateAddressFields(result.address);
        } catch (error) {
          // Keep the selected coordinates even if address lookup fails.
        }
      }

      function clearSearchResults() {
        if (mapSearchResults) mapSearchResults.innerHTML = '';
      }

      function setSearchStatus(message, isError) {
        if (!mapSearchStatus) return;
        if (!message) {
          mapSearchStatus.classList.add('hidden');
          mapSearchStatus.textContent = '';
          mapSearchStatus.classList.remove('text-red-600');
          return;
        }
        mapSearchStatus.textContent = message;
        mapSearchStatus.classList.remove('hidden');
        mapSearchStatus.classList.toggle('text-red-600', Boolean(isError));
      }

      function renderSearchResults(results) {
        clearSearchResults();
        if (!mapSearchResults) return;
        results.forEach((result) => {
          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'w-full rounded-xl border border-brand-ink/10 bg-white px-3 py-3 text-left text-sm text-brand-ink/80 hover:border-brand-ink/25 hover:bg-brand-sand/30';
          button.textContent = result.display_name;
          button.addEventListener('click', () => {
            const lat = parseFloat(result.lat);
            const lng = parseFloat(result.lon);
            if (!Number.isFinite(lat) || !Number.isFinite(lng)) return;
            setMarker(lat, lng);
            map.setView([lat, lng], 16);
            if (mapSearchInput) {
              mapSearchInput.value = result.display_name;
            }
            updateAddressFields(result.address || {});
            clearSearchResults();
            setSearchStatus('Emplacement trouve et place sur la carte.');
          });
          mapSearchResults.appendChild(button);
        });
      }

      async function searchLocation() {
        const query = mapSearchInput ? mapSearchInput.value.trim() : '';
        if (!query) {
          setSearchStatus('Saisissez une adresse ou un lieu a rechercher.', true);
          clearSearchResults();
          return;
        }

        setSearchStatus('Recherche en cours...');
        clearSearchResults();

        try {
          const response = await fetch(`https://nominatim.openstreetmap.org/search?format=jsonv2&addressdetails=1&limit=5&q=${encodeURIComponent(query)}`, {
            headers: {
              Accept: 'application/json'
            }
          });
          if (!response.ok) {
            throw new Error('search_failed');
          }
          const results = await response.json();
          if (!Array.isArray(results) || !results.length) {
            setSearchStatus('Aucun resultat trouve pour cette recherche.', true);
            return;
          }
          setSearchStatus('Choisissez le bon resultat pour definir l emplacement exact.');
          renderSearchResults(results);
        } catch (error) {
          setSearchStatus('La recherche du lieu a echoue. Verifiez la connexion puis reessayez.', true);
        }
      }

      map.on('click', (e) => {
        const { lat, lng } = e.latlng;
        setMarker(lat, lng);
        reverseGeocode(lat, lng);
        setSearchStatus('Emplacement mis a jour depuis la carte.');
      });

      if (mapSearchButton) {
        mapSearchButton.addEventListener('click', searchLocation);
      }

      if (mapSearchInput) {
        mapSearchInput.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') {
            e.preventDefault();
            searchLocation();
          }
        });
      }
    }

    if (mapsInput && (!mapLat.value || !mapLng.value)) {
      mapsInput.addEventListener('change', () => {
        mapLat.value = '';
        mapLng.value = '';
      });
    }

    if (adminForm && mapsInput && mapLat && mapLng) {
      adminForm.addEventListener('submit', () => {
        if (!mapsInput.value && mapLat.value && mapLng.value) {
          mapsInput.value = `https://www.google.com/maps?q=${mapLat.value},${mapLng.value}`;
        }
      });
    }

    const thumbInput = document.getElementById('thumbnailFile');
    const thumbPreview = document.getElementById('thumbnailPreview');
    const thumbImg = thumbPreview ? thumbPreview.querySelector('img') : null;
    const thumbRemove = document.getElementById('thumbnailRemove');
    const galleryInput = document.getElementById('galleryFiles');
    const galleryPreview = document.getElementById('galleryPreview');
    const thumbDrop = document.getElementById('thumbnailDrop');
    const galleryDrop = document.getElementById('galleryDrop');
    const agentAvatarInput = document.getElementById('agentAvatarFile');
    const agentAvatarDrop = document.getElementById('agentAvatarDrop');
    const agentAvatarPreview = document.getElementById('agentAvatarPreview');
    const agentAvatarImg = agentAvatarPreview ? agentAvatarPreview.querySelector('img') : null;

    function showThumb(src) {
      if (!thumbPreview || !thumbImg || !src) return;
      thumbImg.src = src;
      thumbPreview.classList.remove('hidden');
    }

    function clearThumb() {
      if (!thumbInput || !thumbPreview || !thumbImg) return;
      thumbInput.value = '';
      thumbImg.src = '';
      thumbPreview.classList.add('hidden');
    }

    function preventDefaults(e) {
      e.preventDefault();
      e.stopPropagation();
    }

    function highlight(el, on) {
      if (!el) return;
      el.classList.toggle('border-brand-gold', on);
      el.classList.toggle('border-brand-ink/20', !on);
    }

    function handleDropFile(el, input, cb) {
      if (!el || !input) return;
      ['dragenter', 'dragover', 'dragleave', 'drop'].forEach((eventName) => {
        el.addEventListener(eventName, preventDefaults, false);
      });
      ['dragenter', 'dragover'].forEach((eventName) => {
        el.addEventListener(eventName, () => highlight(el, true), false);
      });
      ['dragleave', 'drop'].forEach((eventName) => {
        el.addEventListener(eventName, () => highlight(el, false), false);
      });
      if (el.tagName !== 'LABEL') {
        el.addEventListener('click', () => input.click());
      }
      el.addEventListener('drop', (e) => {
        const files = e.dataTransfer?.files;
        if (files && files.length) {
          input.files = files;
          cb(files);
        }
      });
    }

    if (thumbInput) {
      thumbInput.addEventListener('change', (e) => {
        const file = e.target.files?.[0];
        if (file) {
          const url = URL.createObjectURL(file);
          showThumb(url);
          setTimeout(() => URL.revokeObjectURL(url), 0);
        }
      });
      handleDropFile(thumbDrop, thumbInput, (files) => {
        const file = files[0];
        if (!file) return;
        const url = URL.createObjectURL(file);
        showThumb(url);
        setTimeout(() => URL.revokeObjectURL(url), 0);
      });
    }
    if (thumbRemove) {
      thumbRemove.addEventListener('click', clearThumb);
    }

    if (agentAvatarInput) {
      const showAvatar = (src) => {
        if (!agentAvatarPreview || !agentAvatarImg || !src) return;
        agentAvatarImg.src = src;
        agentAvatarPreview.classList.remove('hidden');
      };
      agentAvatarInput.addEventListener('change', (e) => {
        const file = e.target.files?.[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = (ev) => showAvatar(ev.target?.result);
          reader.readAsDataURL(file);
        }
      });
      handleDropFile(agentAvatarDrop, agentAvatarInput, (files) => {
        const file = files?.[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = (ev) => showAvatar(ev.target?.result);
        reader.readAsDataURL(file);
      });
    }

    if (galleryInput && galleryPreview) {
      let currentGalleryFiles = [];

      function syncGalleryInput() {
        const dt = new DataTransfer();
        currentGalleryFiles.forEach((file) => dt.items.add(file));
        galleryInput.files = dt.files;
      }

      function renderGallery() {
        galleryPreview.innerHTML = '';
        if (!currentGalleryFiles.length) {
          galleryPreview.classList.add('hidden');
          return;
        }
        currentGalleryFiles.forEach((file, index) => {
          const url = URL.createObjectURL(file);
          const wrap = document.createElement('div');
          wrap.className = 'relative';
          const img = document.createElement('img');
          img.src = url;
          img.className = 'h-20 w-full object-cover rounded-lg border border-brand-ink/10';
          img.onload = () => URL.revokeObjectURL(url);
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'absolute -top-2 -right-2 h-6 w-6 rounded-md bg-red-600 text-white flex items-center justify-center shadow';
          btn.innerHTML = '<i class=\"bi bi-trash text-[10px]\"></i>';
          btn.addEventListener('click', () => {
            currentGalleryFiles.splice(index, 1);
            syncGalleryInput();
            renderGallery();
          });
          wrap.appendChild(img);
          wrap.appendChild(btn);
          galleryPreview.appendChild(wrap);
          galleryPreview.classList.remove('hidden');
        });
      }

      function setGalleryFiles(files) {
        currentGalleryFiles = Array.from(files || []).slice(0, 9);
        syncGalleryInput();
        renderGallery();
      }

      galleryInput.addEventListener('change', (e) => {
        setGalleryFiles(e.target.files || []);
      });
      handleDropFile(galleryDrop, galleryInput, (files) => {
        setGalleryFiles(files || []);
      });
    }

    const listContainer = document.getElementById('list-current');
    const searchInput = document.getElementById('adminSearch');
    const statusFilter = document.getElementById('adminStatusFilter');
    const sortSelect = document.getElementById('adminSort');
    const emptyState = document.getElementById('adminListEmpty');
    const showFormBtn = document.getElementById('showFormBtn');
    const hideFormBtn = document.getElementById('hideFormBtn');
    const formSection = document.getElementById('form-current');

    if (showFormBtn && formSection) {
      showFormBtn.addEventListener('click', () => {
        formSection.classList.remove('hidden');
        formSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }

    if (hideFormBtn && formSection) {
      hideFormBtn.addEventListener('click', () => {
        formSection.classList.add('hidden');
      });
    }

    if (listContainer && searchInput && statusFilter && sortSelect) {
      const cards = Array.from(listContainer.querySelectorAll('.property-card'));

      function applyListFilters() {
        const query = searchInput.value.trim().toLowerCase();
        const selectedStatus = statusFilter.value;
        const sortMode = sortSelect.value;

        cards.forEach((card) => {
          const title = card.dataset.title || '';
          const city = card.dataset.city || '';
          const address = card.dataset.address || '';
          const ref = card.dataset.ref || '';
          const status = card.dataset.status || '';
          const matchesText = !query
            || title.includes(query)
            || city.includes(query)
            || address.includes(query)
            || ref.includes(query);
          const matchesStatus = !selectedStatus || status === selectedStatus;
          card.classList.toggle('hidden', !(matchesText && matchesStatus));
        });

        const visibleCards = cards.filter((card) => !card.classList.contains('hidden'));
        visibleCards.sort((left, right) => {
          if (sortMode === 'price-desc') {
            return Number(right.dataset.price || 0) - Number(left.dataset.price || 0);
          }
          if (sortMode === 'price-asc') {
            return Number(left.dataset.price || 0) - Number(right.dataset.price || 0);
          }
          if (sortMode === 'title-asc') {
            return String(left.dataset.title || '').localeCompare(String(right.dataset.title || ''), 'fr');
          }
          return String(right.dataset.created || '').localeCompare(String(left.dataset.created || ''));
        });

        visibleCards.forEach((card) => listContainer.appendChild(card));
        if (emptyState) {
          emptyState.classList.toggle('hidden', visibleCards.length > 0);
        }
      }

      searchInput.addEventListener('input', applyListFilters);
      statusFilter.addEventListener('change', applyListFilters);
      sortSelect.addEventListener('change', applyListFilters);
      applyListFilters();
    }
  })();
</script>

